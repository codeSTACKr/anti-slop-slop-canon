---
/**
 * StateExplorer — three states of the same request, toggled with native radios.
 *
 * generic input → default cleanup (the floor everyone gets) → personalized output
 * (after onboarding). No client JS; all three panels are in the DOM and every
 * control is keyboard-reachable. Radios are direct children so `:checked ~` reaches
 * the panels.
 */
interface State {
  key: string;
  tab: string;
  caption: string;
  body: string;
  meta?: string;
}
interface Props {
  id: string;
  states: State[];
}
const { id, states } = Astro.props;
const name = `state-${id}`;
---

<div class="states">
  {
    states.map((s, i) => (
      <input
        class={`states__radio states__radio--${i}`}
        type="radio"
        name={name}
        id={`${id}-${s.key}`}
        checked={i === 0}
      />
    ))
  }

  <div class="states__tabs" role="group" aria-label="Output state">
    {
      states.map((s) => (
        <label class="states__tab" for={`${id}-${s.key}`}>
          {s.tab}
        </label>
      ))
    }
  </div>

  <div class="states__stage">
    {
      states.map((s, i) => (
        <article class={`states__panel states__panel--${i}`}>
          <p class="states__caption">{s.caption}</p>
          <p class="states__body">{s.body}</p>
          {s.meta && <p class="states__meta">{s.meta}</p>}
        </article>
      ))
    }
  </div>
</div>

<style>
  /* Light paper card with a hard ink offset shadow, matching the other explorers. */
  .states {
    border: var(--rule-thick) solid var(--color-ink);
    background: var(--color-paper);
    box-shadow: var(--shadow-hard);
    overflow: clip;
  }
  .states__radio {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .states__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.75rem;
    border-bottom: var(--rule-mid) solid var(--color-ink);
    background: var(--color-paper-2);
  }
  .states__tab {
    font-family: var(--font-code);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1;
    white-space: nowrap;
    padding: 0.5rem 0.8rem;
    border: var(--rule-mid) solid var(--color-ink);
    background: var(--color-paper);
    color: var(--color-ink);
    cursor: pointer;
    transition:
      background-color 120ms var(--ease-out),
      color 120ms var(--ease-out);
  }
  .states__tab:hover {
    background: var(--color-brand);
    color: var(--color-brand-ink);
  }
  .states__stage {
    padding: 1.4rem 1.3rem;
  }
  .states__panel {
    display: none;
  }
  .states__caption {
    margin: 0 0 0.7rem;
    font-family: var(--font-code);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .states__body {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 1.05rem;
    line-height: 1.62;
    color: var(--color-ink);
    text-wrap: pretty;
    white-space: pre-line;
  }
  .states__meta {
    margin: 1rem 0 0;
    font-family: var(--font-code);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-ink-2);
    border-top: var(--rule-thin) solid var(--color-ink);
    padding-top: 0.8rem;
  }

  /* Selected-tab styling + panel switching for up to three states. */
  .states__radio--0:checked ~ .states__tabs .states__tab:nth-child(1),
  .states__radio--1:checked ~ .states__tabs .states__tab:nth-child(2),
  .states__radio--2:checked ~ .states__tabs .states__tab:nth-child(3) {
    background: var(--color-ink);
    color: var(--color-paper);
  }
  .states__radio--0:focus-visible ~ .states__tabs .states__tab:nth-child(1),
  .states__radio--1:focus-visible ~ .states__tabs .states__tab:nth-child(2),
  .states__radio--2:focus-visible ~ .states__tabs .states__tab:nth-child(3) {
    outline: 3px solid var(--color-ink);
    outline-offset: 2px;
  }
  .states__radio--0:checked ~ .states__stage .states__panel--0,
  .states__radio--1:checked ~ .states__stage .states__panel--1,
  .states__radio--2:checked ~ .states__stage .states__panel--2 {
    display: block;
  }
</style>
