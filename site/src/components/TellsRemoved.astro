---
/**
 * TellsRemoved — the hero mark. A designed typographic panel that names the
 * writing habits the skill removes, each specimen visibly struck through, and
 * resolves to what is left. Theme-consistent with the Terminal system: dark
 * slate card one lightness step above the page, hairline rule, phosphor-green
 * accent on the resolve line only.
 *
 * Pure HTML + CSS. No raster, no network asset, no web font, no JavaScript, and
 * fully legible with JS off. Accessibility: each removed specimen is a real
 * <del> with a real line-through (not color alone) and a visually hidden
 * "removed" prefix, so assistive tech reads "removed game-changer" rather than
 * relying on the strike being seen. The list carries its own group label.
 */
const tells: string[] = [
  "game-changer",
  "“here’s the thing”",
  "seamless",
  "robust",
  "delve",
  "the em dash",
  "the semicolon",
  "exclamation points",
  "rule of three",
  "“in conclusion”",
];
---

<figure class="tells" aria-labelledby="tells-cap">
  <figcaption id="tells-cap" class="tells__cap">
    <span class="tells__cap-text">Habits the skill removes</span>
    <span class="tells__count" aria-hidden="true">{String(tells.length).padStart(2, "0")}</span>
  </figcaption>

  <ul class="tells__grid" aria-label="Writing habits the skill removes">
    {
      tells.map((t, i) => (
        <li class="tells__cell" style={`--i:${i}`}>
          <del class="tells__item">
            <span class="sr-only">removed: </span>
            {t}
          </del>
        </li>
      ))
    }
  </ul>

  <div class="tells__rule" role="presentation"></div>

  <p class="tells__left">
    <span class="tells__left-label">What’s left</span>
    <span class="tells__left-line"
      >your point, in <mark class="mark">your own voice.</mark></span
    >
  </p>
</figure>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tells {
    margin: 0;
    border: var(--rule-thin) solid var(--color-rule);
    background: var(--color-paper-2);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.75rem 1.9rem;
  }
  .tells__cap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.3rem;
    padding-bottom: 0.9rem;
    border-bottom: var(--rule-thin) solid var(--color-rule);
  }
  .tells__cap-text {
    font-family: var(--font-code);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .tells__count {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-brand-ink);
    background: var(--color-brand);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.45rem;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .tells__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .tells__cell {
    display: flex;
  }
  .tells__item {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-ink-2);
    background: var(--color-paper-3);
    border: var(--rule-thin) solid var(--color-rule);
    border-radius: var(--radius-sm);
    padding: 0.32rem 0.68rem;
    /* Real strike line — the signal does not rely on color. */
    text-decoration: line-through;
    text-decoration-color: var(--color-ink-2);
    text-decoration-thickness: 0.12em;
    text-underline-offset: 0;
  }
  .tells__rule {
    height: 0;
    border-top: var(--rule-thin) solid var(--color-rule);
    margin: 1.6rem 0 1.3rem;
  }
  .tells__left {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .tells__left-label {
    font-family: var(--font-code);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }
  .tells__left-line {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-ink);
    text-wrap: pretty;
  }

  @media (prefers-reduced-motion: no-preference) {
    .tells__item {
      position: relative;
      text-decoration: none;
    }
    /* Pseudo bar replaces line-through while animating; avoids a double strike. */
    .tells__item::after {
      content: "";
      position: absolute;
      left: 0.68rem;
      right: 0.68rem;
      top: 50%;
      height: 0.12em;
      background: var(--color-ink-2);
      transform: scaleX(0);
      transform-origin: left;
      translate: 0 -50%;
    }
    .tells__cell {
      opacity: 0;
      animation: chip-rise 440ms var(--ease-out) both;
      animation-delay: calc(var(--i) * 180ms);
    }
    .tells__cell .tells__item {
      animation: chip-flash 440ms var(--ease-out) both, chip-dim 520ms var(--ease-out) both;
      animation-delay: calc(var(--i) * 180ms), calc(var(--i) * 180ms + 240ms);
    }
    .tells__cell .tells__item::after {
      animation: chip-strike 500ms var(--ease-out) both;
      animation-delay: calc(var(--i) * 180ms + 240ms);
    }
    .tells__rule {
      transform: scaleX(0);
      transform-origin: left;
      animation: rule-draw 500ms var(--ease-out) both;
      animation-delay: 2000ms;
    }
    .tells__left {
      opacity: 0;
      animation: chip-rise 600ms var(--ease-out) both;
      animation-delay: 2500ms;
    }
    .tells__left .mark {
      animation: mark-glow 600ms var(--ease-out) both;
      animation-delay: 2500ms;
    }

    /* opacity + rise only */
    @keyframes chip-rise {
      0% {
        opacity: 0;
        transform: translateY(8px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }
    /* green terminal flash on the actual chip border/glow */
    @keyframes chip-flash {
      0% {
        border-color: var(--color-brand);
        box-shadow: 0 0 0.6rem oklch(0.78 0.16 152 / 0.5);
      }
      100% {
        border-color: var(--color-rule);
        box-shadow: none;
      }
    }
    @keyframes chip-dim {
      0% {
        color: var(--color-ink);
      }
      100% {
        color: var(--color-ink-2);
      }
    }
    @keyframes mark-glow {
      0% {
        box-shadow: 0 0 0.6rem oklch(0.78 0.16 152 / 0.5);
      }
      100% {
        box-shadow: none;
      }
    }
    @keyframes chip-strike {
      from {
        transform: scaleX(0);
      }
      to {
        transform: scaleX(1);
      }
    }
    @keyframes rule-draw {
      from {
        transform: scaleX(0);
      }
      to {
        transform: scaleX(1);
      }
    }
  }
</style>
