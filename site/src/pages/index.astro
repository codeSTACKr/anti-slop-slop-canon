---
import Layout from "../layouts/Layout.astro";
import DiffExplorer from "../components/DiffExplorer.astro";
import StateExplorer from "../components/StateExplorer.astro";
import CopyCommand from "../components/CopyCommand.astro";
import TellsRemoved from "../components/TellsRemoved.astro";
import TwoModes from "../components/TwoModes.astro";
import VoiceShift from "../components/VoiceShift.astro";

// Curated Markdown, compiled at build time (no client-side Markdown parser).
import { Content as SampleProfile } from "../content/voice-profile.sample.md";
import { Content as RealtimePrompt } from "../content/realtime-prompt.md";

const REPO = "codeSTACKr/anti-slop-slop-canon";

// The default-cleanup diffs use before/after pairs committed to the repository:
// the hero pair is the golden output published in repo/README.md; the punctuation
// pair is a verbatim example from skills/.../references/defaults.md § Short examples.
const heroBefore =
  "We're thrilled to announce a groundbreaking update that unlocks a seamless, robust, and transformative experience. Here's the thing: Smart Filters arrive on August 12, and early tests show a 17% drop in time spent sorting results. This isn't just an update; it's a game-changer for every workflow!";
const heroAfter =
  "Smart Filters arrive on August 12. Early tests show a 17% drop in time spent sorting results.";

const punctBefore =
  "The result is clear: keep both routes—one is faster; one is safer!";
const punctAfter = "Keep both routes. One is faster. The other is safer.";

// The same v2.4 release with and without the skill's guardrails. Every panel is
// OUTPUT for the same v2.4 facts. Panel 1 is a deliberate before: what an assistant writes with no
// help, so the AI tells belong there. Panel 2 cleans it strictly per the bundled
// rules. Panel 3 restates it in one illustrative sample voice.
const states = [
  {
    key: "none",
    tab: "No guardrails",
    caption: "What a typical assistant writes",
    body: "We're thrilled to announce that v2.4 is here, and it's a game-changer! Here's the thing—this groundbreaking release makes your whole workflow feel seamless. The CLI now has a powerful new --watch flag, cold starts are blazing fast (down from 4.2s to a mere 1.8s), and we've finally squashed that pesky Windows bug that kept dropping your environment variables. You're going to love it!",
    meta: "A realistic draft from an assistant with no help. The hype and the ornamental punctuation are exactly the habits the skill removes.",
  },
  {
    key: "default",
    tab: "With our defaults",
    caption: "Cleaned with the bundled defaults",
    body: "Version 2.4 ships Thursday. The CLI gets a --watch flag. Cold start drops from 4.2 seconds to 1.8 seconds. The Windows bug that dropped environment variables is fixed.",
    meta: "The floor everyone gets. Plain and factual, defensible line by line, with no hype and no invented claim.",
  },
  {
    key: "profile",
    tab: "With your profile",
    caption: "In a sample personal voice",
    body: "2.4 lands Thursday. The CLI finally gets a --watch flag. Cold start went from 4.2 seconds to 1.8. And that Windows bug that ate your environment variables is gone.\nShip it.",
    meta: "Illustrative of one sample profile: clipped first person, dry understatement, a fixed sign-off. It uses only the facts above. Your onboarded output would sound like you.",
  },
];
---

<Layout
  title="anti-slop-slop-canon · sound like yourself"
  description="An open-source Agent Skill that removes AI-writing habits, then learns your voice. Every example on this page is real output from the project's own rules."
>
  <a class="skip" href="#main">Skip to content</a>

  <header class="mast">
    <div class="wrap mast__inner">
      <a class="mast__word" href="#main">anti-slop-slop-canon</a>
      <nav class="mast__nav" aria-label="Primary">
        <a class="mast__link" href="#install">Install</a>
        <a
          class="mast__star"
          href={`https://github.com/${REPO}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="mast__star-glyph"
            viewBox="0 0 24 24"
            width="15"
            height="15"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M12 2.2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6-5.9-3.2-5.9 3.2 1.2-6.6L2.5 9.2l6.6-.9z"
            ></path>
          </svg>
          Star on GitHub
        </a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- HERO — poster -->
    <section class="hero wrap">
      <p class="hero__kicker">
        <span class="hero__kicker-tag">Open source</span>
        <span class="hero__kicker-text">An Agent Skill</span>
      </p>
      <h1 class="hero__title">Sound like yourself.</h1>
      <p class="hero__lede typeset">
        <code>anti-slop-slop-canon</code> removes the habits that make writing sound
        machine-made, then learns a transparent, editable profile of your voice. One
        profile for written and spoken content.
      </p>
      <p class="hero__sub">
        Every example below is <mark class="mark">real output</mark> from the project's
        own rules.
      </p>

      <div class="hero__flow">
        <TellsRemoved />
      </div>
    </section>

    <!-- PROOF — default cleanup, interactive diff -->
    <section id="proof" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">01</span>
        <span class="shead__label">The floor</span>
        <h2 class="shead__title">Default cleanup, before you do anything</h2>
      </header>
      <p class="lead typeset">
        Out of the box it strips hype, canned framing, and ornamental punctuation
        without inventing a claim the source never made.
      </p>

      <div class="stack">
        <DiffExplorer
          id="hero"
          label="Product update · rewrite"
          before={heroBefore}
          after={heroAfter}
          note="Same facts. Removed the hype, a manufactured contrast, and an exclamation point."
        />
        <DiffExplorer
          id="punct"
          label="Punctuation · rewrite"
          before={punctBefore}
          after={punctAfter}
          note="No em dash, no semicolon, no exclamation point, no mid-sentence colon."
        />
      </div>
    </section>

    <!-- GUARDRAILS -->
    <section id="states" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">02</span>
        <span class="shead__label">Guardrails</span>
        <h2 class="shead__title">From a raw draft to your own voice</h2>
      </header>
      <p class="lead typeset">
        Without the skill, an assistant leans on hype and ornamental punctuation. The
        bundled defaults remove those habits from any draft. Add your profile and the
        same facts come out sounding like you.
      </p>
      <StateExplorer id="release" states={states} />
    </section>

    <!-- WRITTEN & SPOKEN -->
    <section id="voice" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">03</span>
        <span class="shead__label">One profile, two modes</span>
        <h2 class="shead__title">Written and spoken</h2>
      </header>
      <p class="lead typeset">
        The same profile covers what people read and what they hear.
      </p>

      <TwoModes />

      <div class="grid2">
        <article class="card">
          <div class="card__head">
            <h3 class="card__title">Written</h3>
            <p class="card__desc">Blog posts, docs, and social posts</p>
          </div>
          <div class="card__body">
            <p class="ex__caption">Before</p>
            <p class="ex__before">This isn't a redesign. It's a reset.</p>
            <p class="ex__caption">After</p>
            <p class="ex__after">
              This redesign changes the navigation and search model.
            </p>
            <p class="ex__src">
              A blog opener with the contrast framing removed, from the bundled defaults.
            </p>
          </div>
        </article>

        <article class="card">
          <div class="card__head">
            <h3 class="card__title">Spoken</h3>
            <p class="card__desc">Video scripts, narration, voice-agent replies</p>
          </div>
          <div class="card__body">
            <p class="ex__caption">Before</p>
            <p class="ex__lead-line">Deploying takes three steps:</p>
            <ul class="ex__strucklist">
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>1.</del>
                Pull the latest main.
              </li>
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>2.</del>
                Run the database migration.
              </li>
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>3.</del>
                Restart the workers.
              </li>
            </ul>
            <p class="ex__caption">After</p>
            <p class="ex__after">
              Deploying takes three steps. First, pull the latest main. Then run the
              database migration. Last, restart the workers.
            </p>
            <p class="ex__src">
              The list numbers drop out, so they are never read aloud. The order stays
              the same.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- ONBOARDING -->
    <section id="onboarding" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">04</span>
        <span class="shead__label">How it learns your voice</span>
        <h2 class="shead__title">It builds a profile from your own writing</h2>
      </header>
      <p class="lead typeset">
        You give it a few samples. It finds the traits that are your voice, compiles a
        profile you approve, and writes in your voice from then on.
      </p>

      <VoiceShift />

      <div class="firstrun">
        <h3 class="firstrun__h">The first time, it offers three ways to start</h3>
        <div class="choices">
          <div class="choice">
            <span class="choice__n">1</span>
            <div>
              <h4 class="choice__h">Personalize now</h4>
              <p class="choice__p">
                A short, adaptive interview. One question at a time.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">2</span>
            <div>
              <h4 class="choice__h">Use the defaults</h4>
              <p class="choice__p">
                Skip setup and use the bundled defaults right away.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">3</span>
            <div>
              <h4 class="choice__h">Defer</h4>
              <p class="choice__p">
                Not now. Use the defaults and ask again later.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROFILE -->
    <section id="profile" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">05</span>
        <span class="shead__label">Nothing hidden</span>
        <h2 class="shead__title">A transparent, editable profile</h2>
      </header>
      <p class="lead typeset">
        The compiled profile is a plain Markdown file in your project, not inside the
        installed skill. Open it and edit any rule. The skill leaves your edits alone.
      </p>

      <figure class="filecard">
        <figcaption class="filecard__bar">
          <span class="filecard__marker" aria-hidden="true"></span>
          <span class="filecard__name">voice-profile.md</span>
          <span class="filecard__tag">example</span>
        </figcaption>
        <div class="filecard__body typeset" data-density="compact">
          <SampleProfile />
        </div>
      </figure>
    </section>

    <!-- REALTIME -->
    <section id="realtime" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">06</span>
        <span class="shead__label">For voice agents</span>
        <h2 class="shead__title">A realtime voice prompt</h2>
      </header>
      <p class="lead typeset">
        Ask for the realtime prompt and the skill returns a compact, style-only module
        for a voice agent's system prompt. It shapes delivery only, so it sits beside
        your agent's own instructions rather than replacing them.
      </p>

      <article class="doc">
        <div class="doc__head">
          <h3 class="doc__title">Bundled default module</h3>
        </div>
        <div class="doc__body">
          <div class="typeset doc__prose">
            <RealtimePrompt />
          </div>
        </div>
      </article>
    </section>

    <!-- INSTALL -->
    <section id="install" class="section wrap">
      <header class="shead">
        <span class="shead__num" aria-hidden="true">07</span>
        <span class="shead__label">Getting started</span>
        <h2 class="shead__title">Install</h2>
      </header>
      <p class="lead typeset">
        Installation uses <code>npx skills</code>. A project copy keeps its own state
        and never falls back to the global one.
      </p>

      <div class="install-card">
        <div class="install-row">
          <h3 class="install-row__name">Global</h3>
          <p class="install-row__note">
            Activates the skill in every project on the machine.
          </p>
          <div class="install-row__cmd">
            <CopyCommand command={`npx skills add ${REPO} -g`} />
          </div>
        </div>
        <div class="install-row">
          <h3 class="install-row__name">Project</h3>
          <p class="install-row__note">
            Scoped to one repository, with its own isolated state.
          </p>
          <div class="install-row__cmd">
            <CopyCommand command={`npx skills add ${REPO}`} />
          </div>
        </div>
      </div>

      <p class="fineprint">
        It works with coding agents that read Agent Skills, including Claude Code,
        Cursor, and Codex.
      </p>

      <div class="cta">
        <a class="btn" href={`https://github.com/${REPO}`}>View the repository</a>
        <a class="btn btn--ghost" href="#proof">Back to the examples</a>
      </div>

      <p class="body typeset">
        This skill will not help you evade AI-detection tools and makes no claim that
        its output is undetectable. Its purpose is to remove habits that make writing
        sound generic and to help you sound like yourself.
      </p>
    </section>
  </main>

  <footer class="colophon">
    <div class="wrap colophon__inner">
      <span class="colophon__accent" aria-hidden="true"></span>
      <p class="colophon__statement">Sound like yourself.</p>
      <div class="colophon__grid">
        <div class="colophon__brand">
          <span class="colophon__word">anti-slop-slop-canon</span>
          <span class="colophon__tag">Removes the habits. Learns your voice.</span>
        </div>
        <div class="colophon__cols">
          <div>
            <h2 class="colophon__h">Repository</h2>
            <ul>
              <li><a href={`https://github.com/${REPO}`}>Source</a></li>
              <li>
                <a href={`https://github.com/${REPO}/tree/main/skills`}>The skill</a>
              </li>
              <li><a href={`https://github.com/${REPO}/tree/main/docs`}>Docs</a></li>
              <li><a href={`https://github.com/${REPO}/tree/main/evals`}>Evals</a></li>
            </ul>
          </div>
          <div>
            <h2 class="colophon__h">On this page</h2>
            <ul>
              <li><a href="#proof">Default cleanup</a></li>
              <li><a href="#states">Guardrail levels</a></li>
              <li><a href="#voice">Written &amp; spoken</a></li>
              <li><a href="#realtime">Realtime prompt</a></li>
            </ul>
          </div>
          <div>
            <h2 class="colophon__h">License</h2>
            <ul>
              <li>MIT licensed</li>
              <li><a href={`https://github.com/${REPO}`}>Open source</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <style>
    .skip {
      position: absolute;
      left: -9999px;
      top: 0;
      background: var(--color-ink);
      color: var(--color-paper);
      padding: 0.6rem 1rem;
      z-index: 50;
      font-weight: 700;
    }
    .skip:focus {
      left: 0;
    }

    .wrap {
      width: 100%;
      max-width: 64rem;
      margin-inline: auto;
      padding-inline: 1.25rem;
    }

    /* Masthead — N7 brutal slab: heavy wordmark, thick bottom rule, hard-edged
       Star button. */
    .mast {
      border-bottom: var(--rule-heavy) solid var(--color-ink);
      background: var(--color-paper);
    }
    .mast__inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem 1.5rem;
      padding-block: 0.9rem;
    }
    .mast__word {
      font-family: var(--font-code);
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--color-ink);
      text-decoration: none;
    }
    .mast__word:hover {
      background: var(--color-brand);
      color: var(--color-brand-ink);
    }
    .mast__nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem 0.9rem;
    }
    .mast__link {
      font-family: var(--font-code);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--color-ink);
      text-decoration: none;
      line-height: 1;
      padding: 0.55rem 0.4rem;
    }
    .mast__link:hover {
      text-decoration: underline;
      text-decoration-thickness: 0.14em;
      text-underline-offset: 0.2em;
      text-decoration-color: var(--color-brand);
    }
    /* Star-on-GitHub — a hard-edged slab button, no count and no fetch. */
    .mast__star {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 0.85rem;
      border: var(--rule-mid) solid var(--color-ink);
      background: var(--color-paper);
      box-shadow: var(--shadow-hard);
      font-family: var(--font-code);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--color-ink);
      text-decoration: none;
      white-space: nowrap;
      transition:
        transform 120ms var(--ease-out),
        box-shadow 120ms var(--ease-out),
        background-color 120ms var(--ease-out);
    }
    .mast__star:hover {
      background: var(--color-brand);
      transform: translate(-1px, -1px);
      box-shadow: var(--shadow-hard-lg);
    }
    .mast__star:active {
      transform: translate(2px, 2px);
      box-shadow: 1px 1px 0 0 var(--color-ink);
    }
    .mast__star-glyph {
      flex: 0 0 auto;
      color: var(--color-ink);
    }

    /* Hero — poster scale. Heavier bottom padding pulls it into the next section. */
    .hero {
      padding-block: 3rem 4.5rem;
    }
    .hero__kicker {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.65rem;
      margin: 0 0 1.6rem;
      font-family: var(--font-code);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1;
    }
    .hero__kicker-tag {
      background: var(--color-brand);
      color: var(--color-brand-ink);
      padding: 0.4rem 0.55rem;
      border: var(--rule-mid) solid var(--color-ink);
    }
    .hero__kicker-text {
      color: var(--color-ink-2);
    }
    .hero__title {
      margin: 0;
      font-size: clamp(3.1rem, 13vw, 8.5rem);
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.035em;
      text-transform: uppercase;
    }
    .hero__lede {
      margin: 1.9rem 0 0;
      font-size: clamp(1.15rem, 2.3vw, 1.5rem);
      line-height: 1.5;
      font-weight: 500;
      max-width: 46ch;
    }
    .hero__sub {
      margin: 1.5rem 0 0;
      font-family: var(--font-code);
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.6;
      color: var(--color-ink);
      max-width: 60ch;
    }
    .hero__flow {
      margin-top: 3rem;
    }

    /* Sections — thick top rule between blocks */
    .section {
      padding-block: 4.25rem;
    }
    /* A heavier rule opens the first section under the hero. */
    #proof {
      border-top: var(--rule-heavy) solid var(--color-ink);
    }
    #states,
    #voice,
    #onboarding,
    #profile,
    #realtime,
    #install {
      border-top: var(--rule-thick) solid var(--color-ink);
    }

    /* Section head — oversized numeral, mono label, heavy uppercase title.
       Single-column vertical stack (never tag-left / heading-right). */
    .shead {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      margin: 0 0 1.5rem;
    }
    .shead__num {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 11vw, 7rem);
      font-weight: 800;
      line-height: 0.82;
      letter-spacing: -0.04em;
      color: var(--color-ink);
      -webkit-text-stroke: 2px var(--color-ink);
      color: transparent;
      margin-bottom: 0.35rem;
    }
    .shead__label {
      font-family: var(--font-code);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-ink-2);
    }
    .shead__title {
      margin: 0;
      font-size: clamp(1.85rem, 5.5vw, 3.4rem);
      line-height: 1.02;
      font-weight: 800;
      letter-spacing: -0.02em;
      text-transform: uppercase;
    }
    .lead {
      margin: 0 0 2.25rem;
      font-size: 1.14rem;
      font-weight: 500;
      max-width: 60ch;
    }
    .body {
      margin-top: 1.9rem;
      font-weight: 500;
    }
    .fineprint {
      margin: 1.1rem 0 0;
      font-family: var(--font-code);
      font-size: 0.8rem;
      line-height: 1.55;
      color: var(--color-ink-2);
    }
    /* Inline code — a hard-edged mono chip. */
    .fineprint code,
    .lead code,
    .body code,
    .hero__lede code {
      font-family: var(--font-code);
      font-size: 0.86em;
      background: var(--color-paper-2);
      padding: 0.08em 0.34em;
      border: var(--rule-thin) solid var(--color-ink);
      font-weight: 600;
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    /* Brutalist card — hard border + offset shadow. Used for Written / Spoken. */
    .card {
      border: var(--rule-thick) solid var(--color-ink);
      background: var(--color-paper);
      box-shadow: var(--shadow-hard);
    }
    .card__head {
      padding: 1.1rem 1.25rem;
      border-bottom: var(--rule-thick) solid var(--color-ink);
      background: var(--color-paper-2);
    }
    .card__title {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.01em;
    }
    .card__desc {
      margin: 0.35rem 0 0;
      font-family: var(--font-code);
      font-size: 0.8rem;
      color: var(--color-ink-2);
    }
    .card__body {
      padding: 1.25rem;
    }

    /* File-styled profile panel — hard-edged, filename bar, no fake window chrome. */
    .filecard {
      margin: 0;
      max-width: 46rem;
      border: var(--rule-thick) solid var(--color-ink);
      background: var(--color-paper);
      box-shadow: var(--shadow-hard-lg);
      overflow: clip;
    }
    .filecard__bar {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.7rem 1.1rem;
      border-bottom: var(--rule-thick) solid var(--color-ink);
      background: var(--color-ink);
    }
    .filecard__marker {
      width: 0.7rem;
      height: 0.7rem;
      flex: 0 0 auto;
      background: var(--color-brand);
    }
    .filecard__name {
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 700;
      color: var(--color-paper);
    }
    .filecard__tag {
      margin-left: auto;
      font-family: var(--font-code);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--color-ink);
      background: var(--color-brand);
      padding: 0.15rem 0.4rem;
    }
    .filecard__body {
      padding: 1.5rem 1.7rem 1.8rem;
    }
    .filecard__body :global(> :first-child) {
      margin-top: 0;
    }

    /* Realtime module — a LIGHT card with a dark title bar (allowed sparingly), so
       the voice module reads as a distinct, considered block. Not fake terminal
       chrome: a labelled panel with prose inside. */
    .doc {
      max-width: 46rem;
      border: var(--rule-thick) solid var(--color-ink);
      background: var(--color-paper);
      box-shadow: var(--shadow-hard);
      overflow: clip;
    }
    .doc__head {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.35rem 1rem;
      padding: 0.9rem 1.4rem;
      border-bottom: var(--rule-thick) solid var(--color-ink);
      background: var(--color-ink);
    }
    .doc__title {
      margin: 0;
      font-size: 1.15rem;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--color-paper);
    }
    .doc__desc {
      margin: 0;
      font-family: var(--font-code);
      font-size: 0.78rem;
      color: var(--color-paper-2);
    }
    .doc__desc code {
      font-family: var(--font-code);
      color: var(--color-brand);
    }
    .doc__body {
      padding: 1.75rem 1.7rem 1.9rem;
    }
    /* Considered typographic treatment: a comfortable measure, roomy leading, and a
       hairline rule between each paragraph of the module, so the block reads as a set
       of distinct instructions rather than a paragraph wall. */
    .doc__prose {
      --typeset-measure: 64ch;
      --typeset-leading: 1.72;
      font-size: 1.02rem;
    }
    .doc__body :global(.doc__prose > p + p) {
      margin-top: 1.5em;
      padding-top: 1.5em;
      border-top: var(--rule-thin) solid var(--color-ink);
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 46rem) {
      .grid2 {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    /* Example text */
    .ex__caption {
      margin: 1rem 0 0.35rem;
      font-family: var(--font-code);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-ink-2);
    }
    .ex__caption:first-child {
      margin-top: 0;
    }
    .ex__before {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink-2);
      text-decoration: line-through;
      text-decoration-thickness: 0.09em;
      text-decoration-color: var(--color-ink);
    }
    .ex__after {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      font-weight: 600;
      color: var(--color-ink);
    }
    .ex__lead-line {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink);
    }
    /* Spoken "before" — the written numbered list, with the numbers struck to
       signal the list structure dropped for speech (parallel to the Written card's
       struck before). The step words stay; only the markers are removed. */
    .ex__strucklist {
      margin: 0.4rem 0 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .ex__strucklist li {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink);
    }
    .ex__strucknum {
      font-weight: 700;
      color: var(--color-ink-2);
      text-decoration: line-through;
      text-decoration-thickness: 0.12em;
      text-decoration-color: var(--color-ink);
      margin-right: 0.15rem;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .ex__src {
      margin: 1.1rem 0 0;
      font-family: var(--font-code);
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }

    /* Onboarding choices — hard-edged tiles with a big brand numeral. */
    .choices {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    @media (min-width: 46rem) {
      .choices {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    .choice {
      display: flex;
      gap: 0.85rem;
      padding: 1.15rem;
      border: var(--rule-mid) solid var(--color-ink);
      background: var(--color-paper);
    }
    .choice__n {
      flex: 0 0 auto;
      font-family: var(--font-display);
      font-size: 1.9rem;
      font-weight: 800;
      line-height: 0.9;
      color: var(--color-ink);
      background: var(--color-brand);
      border: var(--rule-mid) solid var(--color-ink);
      width: 2.4rem;
      height: 2.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .choice__h {
      margin: 0 0 0.35rem;
      font-size: 1.05rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.01em;
    }
    .choice__p {
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }

    .firstrun {
      margin-top: 2rem;
      padding-top: 1.75rem;
      border-top: var(--rule-thick) solid var(--color-ink);
    }
    .firstrun__h {
      margin: 0 0 1.1rem;
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--color-ink);
    }

    /* Install — ONE card holding both scopes, each as a labeled row (name, scope
       note, command) separated by a hard rule. */
    .install-card {
      border: var(--rule-thick) solid var(--color-ink);
      background: var(--color-paper);
      box-shadow: var(--shadow-hard);
    }
    .install-row {
      padding: 1.4rem;
    }
    .install-row + .install-row {
      border-top: var(--rule-thick) solid var(--color-ink);
    }
    .install-row__name {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.01em;
    }
    .install-row__note {
      margin: 0.4rem 0 0;
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }
    .install-row__cmd {
      margin-top: 1.1rem;
    }
    /* Let the command wrap at spaces so the whole command stays visible without a
       horizontal scroll. Scoped to install only. */
    .install-row__cmd :global(.cmd__code) {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      overflow-x: visible;
    }

    /* Brutalist buttons */
    .cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 2rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      padding: 0.85rem 1.35rem;
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      white-space: nowrap;
      text-decoration: none;
      border: var(--rule-mid) solid var(--color-ink);
      background: var(--color-ink);
      color: var(--color-paper);
      box-shadow: var(--shadow-hard);
      transition:
        transform 120ms var(--ease-out),
        box-shadow 120ms var(--ease-out),
        background-color 120ms var(--ease-out),
        color 120ms var(--ease-out);
    }
    .btn:hover {
      background: var(--color-brand);
      color: var(--color-brand-ink);
      transform: translate(-1px, -1px);
      box-shadow: var(--shadow-hard-lg);
    }
    .btn:active {
      transform: translate(2px, 2px);
      box-shadow: 1px 1px 0 0 var(--color-ink);
    }
    .btn--ghost {
      background: var(--color-paper);
      color: var(--color-ink);
    }

    /* Colophon — Ft7 brutal statement on a LIGHT body, with a heavy top rule and one
       small brand accent bar. */
    .colophon {
      border-top: var(--rule-heavy) solid var(--color-ink);
      background: var(--color-paper);
      padding-block: 3rem 3.25rem;
    }
    .colophon__accent {
      display: block;
      width: 3.5rem;
      height: 0.5rem;
      margin-bottom: 1.25rem;
      background: var(--color-brand);
      border: var(--rule-mid) solid var(--color-ink);
    }
    .colophon__statement {
      margin: 0 0 2.25rem;
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 10vw, 6rem);
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.03em;
      text-transform: uppercase;
      color: var(--color-ink);
      overflow-wrap: anywhere;
      min-width: 0;
    }
    .colophon__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 46rem) {
      .colophon__grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr);
        align-items: start;
      }
    }
    .colophon__word {
      display: block;
      font-family: var(--font-code);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--color-ink);
    }
    .colophon__tag {
      display: block;
      margin-top: 0.5rem;
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-ink-2);
      max-width: 24ch;
    }
    .colophon__cols {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
      gap: 1.75rem;
    }
    .colophon__h {
      margin: 0 0 0.7rem;
      font-family: var(--font-code);
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-ink-2);
    }
    .colophon__cols ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .colophon__cols li {
      font-size: 0.9rem;
      color: var(--color-ink-2);
    }
    .colophon__cols a {
      color: var(--color-ink);
      text-decoration: underline;
      text-decoration-thickness: 0.1em;
      text-underline-offset: 0.15em;
      text-decoration-color: var(--color-brand);
      font-weight: 600;
    }
    .colophon__cols a:hover {
      background: var(--color-brand);
      color: var(--color-brand-ink);
      text-decoration-color: transparent;
    }
  </style>
</Layout>
