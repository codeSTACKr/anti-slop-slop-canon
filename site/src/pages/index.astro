---
import Layout from "../layouts/Layout.astro";
import DiffExplorer from "../components/DiffExplorer.astro";
import StateExplorer from "../components/StateExplorer.astro";
import CopyCommand from "../components/CopyCommand.astro";
import TellsRemoved from "../components/TellsRemoved.astro";
import TwoModes from "../components/TwoModes.astro";
import VoiceShift from "../components/VoiceShift.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";

// Curated Markdown, compiled at build time (no client-side Markdown parser).
import { Content as ProfileExcerpt } from "../content/profile-excerpt.md";
import { Content as RealtimePrompt } from "../content/realtime-prompt.md";
import { Content as RulesExcerpt } from "../content/rules-excerpt.md";

const REPO = "codeSTACKr/anti-slop-slop-canon";

// The default-cleanup diffs use before/after pairs committed to the repository:
// the hero pair is the golden output published in repo/README.md; the punctuation
// pair is a verbatim example from skills/.../references/defaults.md § Short examples.
const heroBefore =
  "We're thrilled to announce a groundbreaking update that unlocks a seamless, robust, and transformative experience. Here's the thing: Smart Filters arrive on August 12, and early tests show a 17% drop in time spent sorting results. This isn't just an update; it's a game-changer for every workflow!";
const heroAfter =
  "Smart Filters arrive on August 12. Early tests show a 17% drop in time spent sorting results.";

const punctBefore =
  "The result is clear: keep both routes—one is faster; one is safer!";
const punctAfter = "Keep both routes. One is faster. The other is safer.";

// One release, three levels of guardrail. Every panel is OUTPUT for the same
// v2.4 facts. Panel 1 is a deliberate before: what an assistant writes with no
// help, so the AI tells belong there. Panel 2 cleans it strictly per the bundled
// rules. Panel 3 restates it in one illustrative sample voice.
const states = [
  {
    key: "none",
    tab: "No guardrails",
    caption: "What a typical assistant writes",
    body: "We're thrilled to announce that v2.4 is here, and it's a game-changer! Here's the thing—this groundbreaking release makes your whole workflow feel seamless. The CLI now has a powerful new --watch flag, cold starts are blazing fast (down from 4.2s to a mere 1.8s), and we've finally squashed that pesky Windows bug that kept dropping your environment variables. You're going to love it!",
    meta: "A realistic draft from an assistant with no help. The hype and the ornamental punctuation are exactly the habits the skill removes.",
  },
  {
    key: "default",
    tab: "With our defaults",
    caption: "Cleaned with the bundled defaults",
    body: "Version 2.4 ships Thursday. The CLI gets a --watch flag. Cold start drops from 4.2 seconds to 1.8 seconds. The Windows bug that dropped environment variables is fixed.",
    meta: "The floor everyone gets. Plain and factual, defensible line by line, with no hype and no invented claim.",
  },
  {
    key: "profile",
    tab: "With your profile",
    caption: "In a sample personal voice",
    body: "2.4 lands Thursday. The CLI finally gets a --watch flag. Cold start went from 4.2 seconds to 1.8. And that Windows bug that ate your environment variables is gone.\nShip it.",
    meta: "Illustrative of one sample profile: clipped first person, dry understatement, a fixed sign-off. It uses only the facts above. Your onboarded output would sound like you.",
  },
];

const navLinks = [
  { href: "#proof", label: "Proof" },
  { href: "#states", label: "Guardrail levels" },
  { href: "#voice", label: "Written & spoken" },
  { href: "#onboarding", label: "Onboarding" },
  { href: "#profile", label: "Profile" },
  { href: "#install", label: "Install" },
];
---

<Layout
  title="anti-slop-slop-canon · sound like yourself"
  description="An open-source Agent Skill that removes AI-writing habits, then learns your voice. Every example on this page is real output from the project's own rules."
>
  <a class="skip" href="#main">Skip to content</a>

  <header class="mast">
    <div class="wrap mast__inner">
      <div class="mast__brand">
        <a class="mast__word" href="#main">anti-slop-slop-canon</a>
      </div>
      <nav class="mast__nav" aria-label="Sections">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
    </div>
    <div class="mast__rule" role="presentation"></div>
  </header>

  <main id="main" class="wrap">
    <!-- HERO — typographic, Long Document lede -->
    <section class="hero">
      <p class="hero__kicker">An open-source Agent Skill</p>
      <h1 class="hero__title">Sound like yourself.</h1>
      <p class="hero__lede typeset">
        <code>anti-slop-slop-canon</code> removes the habits that make writing sound
        machine-made, then learns a transparent, editable profile of your actual
        voice. One profile governs both what you write and what you say aloud. It runs
        on the model your agent already has.
      </p>
      <p class="hero__sub">
        Every example below is real output from the project's own rules.
      </p>

      <div class="hero__flow">
        <TellsRemoved />
      </div>
    </section>

    <Separator />

    <!-- PROOF — default cleanup, interactive diff -->
    <section id="proof" class="section">
      <p class="eyebrow">The floor</p>
      <h2 class="h2">Default cleanup, before you do anything</h2>
      <p class="lead typeset">
        Out of the box the skill strips hype, canned framing, and ornamental
        punctuation without inventing a claim the source never made. Toggle between the
        original, the cleaned result, and the exact changes.
      </p>

      <div class="stack">
        <DiffExplorer
          id="hero"
          label="Product update · rewrite"
          before={heroBefore}
          after={heroAfter}
          note="Same feature, same date, same number. Removed the unsupported hype, a manufactured contrast, and an exclamation point."
        />
        <DiffExplorer
          id="punct"
          label="Punctuation · rewrite"
          before={punctBefore}
          after={punctAfter}
          note="No em dash, no semicolon, no exclamation point, no mid-sentence colon. Verbatim example from the bundled defaults."
        />
      </div>
    </section>

    <Separator />

    <!-- THREE STATES -->
    <section id="states" class="section">
      <p class="eyebrow">Three levels of guardrail</p>
      <h2 class="h2">The same release, three levels of guardrail</h2>
      <p class="lead typeset">
        Every panel is output for the same v2.4 release. What changes is how much
        guidance the agent had. First no guardrails, then the shared defaults, then a
        personal profile.
      </p>
      <StateExplorer id="release" states={states} />
      <p class="fineprint">
        The first panel is a deliberate before, written the way an assistant sounds with
        no help. The middle panel applies the bundled rules. The last panel illustrates
        one sample profile and is not a claim about any real person's output.
      </p>
    </section>

    <Separator />

    <!-- WRITTEN & SPOKEN -->
    <section id="voice" class="section">
      <p class="eyebrow">One profile, two modes</p>
      <h2 class="h2">Written and spoken</h2>
      <p class="lead typeset">
        The same profile covers what people read and what they hear. The skill applies
        spoken guidance when text is meant for the ear and written guidance otherwise.
      </p>

      <TwoModes />

      <div class="grid2">
        <Card className="ex">
          <CardHeader>
            <CardTitle>Written</CardTitle>
            <CardDescription>Blog posts, docs, and social posts</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="ex__caption">Before</p>
            <p class="ex__before">This isn't a redesign. It's a reset.</p>
            <p class="ex__caption">After</p>
            <p class="ex__after">
              This redesign changes the navigation and search model.
            </p>
            <p class="ex__src">
              A blog opener with the contrast framing removed, from the bundled defaults.
            </p>
          </CardContent>
        </Card>

        <Card className="ex">
          <CardHeader>
            <CardTitle>Spoken</CardTitle>
            <CardDescription>Video scripts, narration, voice-agent replies</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="ex__caption">Written</p>
            <p class="ex__lead-line">Deploying takes three steps:</p>
            <ol class="ex__list">
              <li>Pull the latest main.</li>
              <li>Run the database migration.</li>
              <li>Restart the workers.</li>
            </ol>
            <p class="ex__caption">Read aloud</p>
            <p class="ex__after">
              Deploying takes three steps. First, pull the latest main. Then run the
              database migration. Last, restart the workers.
            </p>
            <p class="ex__src">
              Read aloud, the list numbers are dropped so a listener never hears them
              counted out. The steps and their order stay the same.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <Separator />

    <!-- ONBOARDING -->
    <section id="onboarding" class="section">
      <p class="eyebrow">How it learns your voice</p>
      <h2 class="h2">It builds a profile from your own writing</h2>
      <p class="lead typeset">
        You give it a few samples. It separates the traits that are your voice from the
        subject you happened to write about and any one-off quirks, compiles a profile
        you preview and approve, and shifts your output toward the way you write.
      </p>

      <VoiceShift />

      <p class="body typeset">
        It asks one question at a time. It writes nothing until you preview and approve
        the profile. By default it keeps none of your samples, pasted text, URLs, or its
        own analysis.
      </p>

      <div class="firstrun">
        <h3 class="firstrun__h">The first time, it offers three ways to start</h3>
        <div class="choices choices--compact">
          <div class="choice">
            <span class="choice__n">1</span>
            <div>
              <h4 class="choice__h">Personalize now</h4>
              <p class="choice__p">
                A short, adaptive interview. One question at a time, samples collected
                early, targeted follow-ups only where the evidence is thin.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">2</span>
            <div>
              <h4 class="choice__h">Use the defaults</h4>
              <p class="choice__p">
                Skip straight to the bundled defaults and resume your task right away. No
                setup, no profile written.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">3</span>
            <div>
              <h4 class="choice__h">Defer</h4>
              <p class="choice__p">
                Not now. The skill uses the defaults for this task and asks again later,
                on your schedule.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Separator />

    <!-- PROFILE + RULES -->
    <section id="profile" class="section">
      <p class="eyebrow">Nothing hidden</p>
      <h2 class="h2">A transparent, editable profile</h2>
      <p class="lead typeset">
        The compiled profile is a plain Markdown file that lives in your project, not
        inside the installed skill. Open it and edit any rule directly. The skill treats
        a direct edit as your intent and will not silently regenerate the file.
      </p>

      <div class="grid2">
        <Card className="doc">
          <CardHeader>
            <CardTitle>Profile schema</CardTitle>
            <CardDescription>
              From <code>assets/voice-profile.template.md</code>
            </CardDescription>
          </CardHeader>
          <CardContent>
            <div class="typeset" data-density="compact">
              <ProfileExcerpt />
            </div>
          </CardContent>
        </Card>

        <Card className="doc">
          <CardHeader>
            <CardTitle>A slice of the default rules</CardTitle>
            <CardDescription>
              From the bundled <code>defaults.md</code>
            </CardDescription>
          </CardHeader>
          <CardContent>
            <div class="typeset" data-density="compact">
              <RulesExcerpt />
            </div>
          </CardContent>
        </Card>
      </div>
    </section>

    <Separator />

    <!-- REALTIME -->
    <section id="realtime" class="section">
      <p class="eyebrow">For voice agents</p>
      <h2 class="h2">A realtime voice prompt</h2>
      <p class="lead typeset">
        Ask for the realtime prompt and the skill returns a compact, style-only module
        to paste into a voice agent's system prompt. It covers delivery only: word
        choice, sentence shape, pacing, first-listen clarity. It defines no tools,
        facts, safety policy, or conversation flow, so it sits beside your agent's own
        instructions rather than replacing them.
      </p>

      <Card className="doc">
        <CardHeader>
          <CardTitle>Bundled default module</CardTitle>
          <CardDescription>
            Verbatim from <code>assets/realtime-voice-prompt.md</code>
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="typeset" data-density="compact">
            <RealtimePrompt />
          </div>
        </CardContent>
      </Card>
    </section>

    <Separator />

    <!-- INSTALL -->
    <section id="install" class="section">
      <p class="eyebrow">Getting started</p>
      <h2 class="h2">Install</h2>
      <p class="lead typeset">
        Installation uses <code>npx skills</code>. Global scope activates the skill in
        every project on the machine; omit the flag to scope it to one repository. A
        project copy reads and writes only its own state and never falls back to the
        global one.
      </p>

      <div class="install">
        <CopyCommand label="Global scope" command={`npx skills add ${REPO} -g`} />
        <CopyCommand label="Project scope" command={`npx skills add ${REPO}`} />
      </div>

      <div class="cta">
        <a
          class={cn(buttonVariants({ variant: "default" }), "h-11 px-5 text-[0.95rem]")}
          href={`https://github.com/${REPO}`}>View the repository</a
        >
        <a
          class={cn(buttonVariants({ variant: "outline" }), "h-11 px-5 text-[0.95rem]")}
          href="#proof">Back to the examples</a
        >
      </div>

      <p class="body typeset">
        This skill will not help you evade AI-detection tools and makes no claim that
        its output is undetectable. Its purpose is to remove habits that make writing
        sound generic and to help you sound like yourself.
      </p>
    </section>
  </main>

  <footer class="colophon">
    <div class="wrap colophon__inner">
      <div class="colophon__brand">
        <span class="colophon__word">anti-slop-slop-canon</span>
        <span class="colophon__tag">Sound like yourself.</span>
      </div>
      <div class="colophon__cols">
        <div>
          <h2 class="colophon__h">Repository</h2>
          <ul>
            <li><a href={`https://github.com/${REPO}`}>Source</a></li>
            <li>
              <a href={`https://github.com/${REPO}/tree/main/skills`}>The skill</a>
            </li>
            <li><a href={`https://github.com/${REPO}/tree/main/docs`}>Docs</a></li>
            <li><a href={`https://github.com/${REPO}/tree/main/evals`}>Evals</a></li>
          </ul>
        </div>
        <div>
          <h2 class="colophon__h">On this page</h2>
          <ul>
            <li><a href="#proof">Default cleanup</a></li>
            <li><a href="#states">Guardrail levels</a></li>
            <li><a href="#voice">Written &amp; spoken</a></li>
            <li><a href="#realtime">Realtime prompt</a></li>
          </ul>
        </div>
        <div>
          <h2 class="colophon__h">License</h2>
          <ul>
            <li>MIT licensed</li>
            <li><a href={`https://github.com/${REPO}`}>Open source</a></li>
          </ul>
        </div>
      </div>
    </div>
  </footer>

  <style>
    .skip {
      position: absolute;
      left: -9999px;
      top: 0;
      background: var(--color-foreground);
      color: var(--color-background);
      padding: 0.6rem 1rem;
      z-index: 50;
      border-radius: 0 0 var(--radius-md) 0;
    }
    .skip:focus {
      left: 0;
    }

    .wrap {
      width: 100%;
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 1.25rem;
    }

    /* Masthead */
    .mast {
      padding-top: 1.4rem;
    }
    .mast__inner {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.75rem 1.5rem;
      padding-bottom: 1rem;
    }
    .mast__brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .mast__word {
      font-family: var(--font-code);
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--color-foreground);
      text-decoration: none;
    }
    .mast__nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1.1rem;
    }
    .mast__nav a {
      font-family: var(--font-ui);
      font-size: 0.86rem;
      color: var(--color-muted-foreground);
      text-decoration: none;
      white-space: nowrap;
    }
    .mast__nav a:hover {
      color: var(--color-foreground);
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }
    .mast__rule {
      height: 0;
      border-top: 2px solid var(--color-foreground);
      border-bottom: 1px solid var(--color-foreground);
      padding-bottom: 3px;
    }

    /* Hero */
    .hero {
      padding-block: 3.5rem 3rem;
    }
    .hero__kicker {
      margin: 0 0 1rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
    .hero__title {
      margin: 0;
      font-size: clamp(2.75rem, 8vw, 4.75rem);
      line-height: 1.02;
      font-weight: 600;
      letter-spacing: -0.02em;
    }
    .hero__lede {
      margin: 1.5rem 0 0;
      font-size: clamp(1.15rem, 2.4vw, 1.4rem);
      line-height: 1.6;
      max-width: 40ch;
    }
    .hero__sub {
      margin: 1.25rem 0 0;
      font-family: var(--font-ui);
      font-size: 0.98rem;
      line-height: 1.6;
      color: var(--color-muted-foreground);
      max-width: 60ch;
    }
    .hero__flow {
      margin-top: 2.5rem;
    }

    /* Sections */
    .section {
      padding-block: 3rem;
    }
    .eyebrow {
      margin: 0 0 0.65rem;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
    .h2 {
      margin: 0;
      font-size: clamp(1.75rem, 4.5vw, 2.6rem);
      line-height: 1.1;
      font-weight: 600;
      letter-spacing: -0.015em;
    }
    .lead {
      margin: 1rem 0 2rem;
      font-size: 1.08rem;
    }
    .body {
      margin-top: 1.75rem;
    }
    .fineprint {
      margin: 1rem 0 0;
      font-family: var(--font-ui);
      font-size: 0.82rem;
      line-height: 1.55;
      color: var(--color-muted-foreground);
    }
    .fineprint code,
    .lead code,
    .body code,
    .hero__lede code {
      font-family: var(--font-code);
      font-size: 0.86em;
      background: var(--color-muted);
      padding: 0.08em 0.32em;
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 46rem) {
      .grid2 {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    /* Example cards */
    .ex__caption {
      margin: 0.9rem 0 0.3rem;
      font-family: var(--font-ui);
      font-size: 0.74rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--color-muted-foreground);
    }
    .ex__caption:first-child {
      margin-top: 0;
    }
    .ex__before {
      margin: 0;
      font-family: var(--font-display);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-del-foreground);
    }
    .ex__after {
      margin: 0;
      font-family: var(--font-display);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-foreground);
    }
    .ex__lead-line {
      margin: 0;
      font-family: var(--font-display);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-foreground);
    }
    .ex__list {
      margin: 0.35rem 0 0;
      padding-left: 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .ex__list li {
      font-family: var(--font-display);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-foreground);
    }
    .ex__src {
      margin: 1rem 0 0;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--color-muted-foreground);
    }
    .ex__src code {
      font-family: var(--font-code);
      font-size: 0.92em;
    }

    /* Onboarding choices */
    .choices {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }
    @media (min-width: 46rem) {
      .choices {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    .choice {
      display: flex;
      gap: 0.85rem;
      padding: 1.25rem;
      border: 1px solid var(--color-rule);
      border-radius: var(--radius-lg);
      background: var(--color-card);
    }
    .choice__n {
      flex: 0 0 auto;
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 600;
      line-height: 1;
      color: var(--color-primary);
    }
    .choice__h {
      margin: 0 0 0.4rem;
      font-size: 1.1rem;
      font-weight: 600;
    }
    .choice__p {
      margin: 0;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      line-height: 1.55;
      color: var(--color-muted-foreground);
    }

    /* First-run choices, now a smaller secondary element under the demo. */
    .firstrun {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-rule);
    }
    .firstrun__h {
      margin: 0 0 1rem;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-foreground);
    }
    .choices--compact {
      margin-bottom: 0;
    }
    .choices--compact .choice {
      padding: 0.9rem 1rem;
    }
    .choices--compact .choice__n {
      font-size: 1.2rem;
    }
    .choices--compact .choice__h {
      font-size: 0.98rem;
      margin-bottom: 0.3rem;
    }
    .choices--compact .choice__p {
      font-size: 0.84rem;
    }

    /* Install */
    .install {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .cta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 2rem;
    }

    /* Colophon */
    .colophon {
      margin-top: 2rem;
      border-top: 2px solid var(--color-foreground);
      background: var(--color-secondary);
      padding-block: 2.5rem 3rem;
    }
    .colophon__inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 46rem) {
      .colophon__inner {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr);
        align-items: start;
      }
    }
    .colophon__word {
      display: block;
      font-family: var(--font-code);
      font-size: 0.95rem;
