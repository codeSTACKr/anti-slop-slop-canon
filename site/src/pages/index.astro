---
import Layout from "../layouts/Layout.astro";
import DiffExplorer from "../components/DiffExplorer.astro";
import StateExplorer from "../components/StateExplorer.astro";
import CopyCommand from "../components/CopyCommand.astro";
import TellsRemoved from "../components/TellsRemoved.astro";
import TwoModes from "../components/TwoModes.astro";
import VoiceShift from "../components/VoiceShift.astro";

// Curated Markdown, compiled at build time (no client-side Markdown parser).
import { Content as SampleProfile } from "../content/voice-profile.sample.md";
import { Content as RealtimePrompt } from "../content/realtime-prompt.md";

const REPO = "codeSTACKr/anti-slop-slop-canon";

async function fetchStars(repo) {
  try {
    const res = await fetch(`https://api.github.com/repos/${repo}`, {
      headers: { Accept: "application/vnd.github+json" },
    });
    if (!res.ok) return null;
    const data = await res.json();
    return typeof data.stargazers_count === "number" ? data.stargazers_count : null;
  } catch {
    return null;
  }
}
function formatStars(n) {
  if (n == null) return null;
  if (n < 1000) return String(n);
  return (n / 1000).toFixed(n < 10000 ? 1 : 0).replace(/\.0$/, "") + "k";
}
const stars = await fetchStars(REPO);
const starsLabel = formatStars(stars);

// The default-cleanup diffs use before/after pairs committed to the repository:
// the hero pair is the golden output published in repo/README.md; the punctuation
// pair is a verbatim example from skills/.../references/defaults.md § Short examples.
const heroBefore =
  "We're thrilled to announce a groundbreaking update that unlocks a seamless, robust, and transformative experience. Here's the thing: Smart Filters arrive on August 12, and early tests show a 17% drop in time spent sorting results. This isn't just an update; it's a game-changer for every workflow!";
const heroAfter =
  "Smart Filters arrive on August 12. Early tests show a 17% drop in time spent sorting results.";

const punctBefore =
  "The result is clear: keep both routes—one is faster; one is safer!";
const punctAfter = "Keep both routes. One is faster. The other is safer.";

// The same v2.4 release with and without the skill's guardrails. Every panel is
// OUTPUT for the same v2.4 facts. Panel 1 is a deliberate before: what an assistant writes with no
// help, so the AI tells belong there. Panel 2 cleans it strictly per the bundled
// rules. Panel 3 restates it in one illustrative sample voice.
const states = [
  {
    key: "none",
    tab: "No guardrails",
    caption: "What a typical assistant writes",
    body: "We're thrilled to announce that v2.4 is here, and it's a game-changer! Here's the thing—this groundbreaking release makes your whole workflow feel seamless. The CLI now has a powerful new --watch flag, cold starts are blazing fast (down from 4.2s to a mere 1.8s), and we've finally squashed that pesky Windows bug that kept dropping your environment variables. You're going to love it!",
    meta: "A realistic draft from an assistant with no help. The hype and the ornamental punctuation are exactly the habits the skill removes.",
  },
  {
    key: "default",
    tab: "With our defaults",
    caption: "Cleaned with the bundled defaults",
    body: "Version 2.4 ships Thursday. The CLI gets a --watch flag. Cold start drops from 4.2 seconds to 1.8 seconds. The Windows bug that dropped environment variables is fixed.",
    meta: "The floor everyone gets. Plain and factual, defensible line by line, with no hype and no invented claim.",
  },
  {
    key: "profile",
    tab: "With your profile",
    caption: "In a sample personal voice",
    body: "2.4 lands Thursday. The CLI finally gets a --watch flag. Cold start went from 4.2 seconds to 1.8. And that Windows bug that ate your environment variables is gone.\nShip it.",
    meta: "Illustrative of one sample profile: clipped first person, dry understatement, a fixed sign-off. It uses only the facts above. Your onboarded output would sound like you.",
  },
];
---

<Layout
  title="anti-slop-slop-canon · sound like yourself"
  description="An open-source Agent Skill that removes AI-writing habits, then learns your voice. Every example on this page is real output from the project’s own rules."
>
  <a class="skip" href="#main">Skip to content</a>

  <header class="nav-term">
    <div class="wrap nav-term__row">
      <a class="nav-term__brand" href="#main"
        ><span class="nav-term__prompt" aria-hidden="true">&gt;</span> anti-slop-slop-canon<span
          class="nav-term__caret"
          aria-hidden="true"></span
        ></a
      >
      <nav class="nav-term__flags" aria-label="Primary">
        <a class="nav-term__flag nav-term__pill" href="#install">--install</a>
        <a
          class="nav-term__flag nav-term__pill nav-term__stars"
          href={`https://github.com/${REPO}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Star the repository on GitHub"
        >
          <span class="nav-term__star" aria-hidden="true">★</span>
          <span class="nav-term__star-count" data-repo={REPO}>{starsLabel ?? "source"}</span>
        </a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- HERO -->
    <section class="hero wrap">
      <p class="hero__kicker">
        <span class="hero__kicker-tag">Open source</span>
        <span class="hero__kicker-text">An Agent Skill</span>
      </p>
      <h1 class="hero__title">Sound like yourself.</h1>
      <p class="hero__lede typeset">
        <code>anti-slop-slop-canon</code> removes the habits that make writing sound
        machine-made, then learns a transparent, editable profile of your voice. One
        profile for written and spoken content.
      </p>
      <p class="hero__sub">
        Every example below is <mark class="mark">real output</mark> from the project’s
        own rules.
      </p>

      <div class="hero__flow">
        <TellsRemoved />
      </div>
    </section>

    <!-- PROOF — default cleanup, interactive diff. Widens past the standard text
         column: the two live diff panels get the extra room, a deliberate width
         break from the rest of the page. -->
    <section id="proof" class="section section--wide wrap">
      <header class="shead">
        <h2 class="shead__title">Default cleanup, before you do anything</h2>
      </header>
      <p class="lead typeset">
        Out of the box it strips hype, canned framing, and ornamental punctuation
        without inventing a claim the source never made.
      </p>

      <div class="stack">
        <DiffExplorer
          id="hero"
          label="Product update · rewrite"
          before={heroBefore}
          after={heroAfter}
          note="Same facts. Removed the hype, a manufactured contrast, and an exclamation point."
        />
        <DiffExplorer
          id="punct"
          label="Punctuation · rewrite"
          before={punctBefore}
          after={punctAfter}
          note="No em dash, no semicolon, no exclamation point, no mid-sentence colon."
        />
      </div>
    </section>

    <!-- GUARDRAILS -->
    <section id="states" class="section wrap">
      <header class="shead">
        <h2 class="shead__title">From a raw draft to your own voice</h2>
      </header>
      <p class="lead typeset">
        Without the skill, an assistant leans on hype and ornamental punctuation. The
        bundled defaults remove those habits from any draft. Add your profile and the
        same facts come out sounding like you.
      </p>
      <StateExplorer id="release" states={states} />
    </section>

    <!-- WRITTEN & SPOKEN -->
    <section id="voice" class="section wrap">
      <header class="shead">
        <h2 class="shead__title">Written and spoken</h2>
      </header>
      <p class="lead typeset">
        The same profile covers what people read and what they hear.
      </p>

      <TwoModes />

      <div class="grid2">
        <article class="card">
          <div class="card__head">
            <h3 class="card__title">Written</h3>
            <p class="card__desc">Blog posts, docs, and social posts</p>
          </div>
          <div class="card__body">
            <p class="ex__caption">Before</p>
            <p class="ex__before">This isn’t a redesign. It’s a reset.</p>
            <p class="ex__caption ex__caption--after">After</p>
            <p class="ex__after">
              This redesign changes the navigation and search model.
            </p>
            <p class="ex__src">
              A blog opener with the contrast framing removed, from the bundled defaults.
            </p>
          </div>
        </article>

        <article class="card">
          <div class="card__head">
            <h3 class="card__title">Spoken</h3>
            <p class="card__desc">Video scripts, narration, voice-agent replies</p>
          </div>
          <div class="card__body">
            <p class="ex__caption">Before</p>
            <p class="ex__lead-line">Deploying takes three steps:</p>
            <ul class="ex__strucklist">
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>1.</del>
                Pull the latest main.
              </li>
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>2.</del>
                Run the database migration.
              </li>
              <li>
                <del class="ex__strucknum"><span class="sr-only">removed: </span>3.</del>
                Restart the workers.
              </li>
            </ul>
            <p class="ex__caption ex__caption--after">After</p>
            <p class="ex__after">
              Deploying takes three steps. First, pull the latest main. Then run the
              database migration. Last, restart the workers.
            </p>
            <p class="ex__src">
              The list numbers drop out, so they are never read aloud. The order stays
              the same.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- ONBOARDING — the deepest padding on the page: this is where the tool learns
         your voice, and the extra air marks it as the page's centre of gravity. -->
    <section id="onboarding" class="section section--roomy wrap">
      <header class="shead">
        <h2 class="shead__title">It builds a profile from your own writing</h2>
      </header>
      <p class="lead typeset">
        You give it a few samples. It finds the traits that are your voice, compiles a
        profile you approve, and writes in your voice from then on.
      </p>

      <VoiceShift />

      <div class="firstrun">
        <h3 class="firstrun__h">The first time, it offers three ways to start</h3>
        <div class="choices">
          <div class="choice">
            <span class="choice__n">1</span>
            <div>
              <h4 class="choice__h">Personalize now</h4>
              <p class="choice__p">
                A short, adaptive interview. One question at a time.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">2</span>
            <div>
              <h4 class="choice__h">Use the defaults</h4>
              <p class="choice__p">
                Skip setup and use the bundled defaults right away.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">3</span>
            <div>
              <h4 class="choice__h">Defer</h4>
              <p class="choice__p">
                Not now. Use the defaults and ask again later.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROFILE — the file card bleeds past the section's own text column, a
         deliberate grid-break rather than another same-width card. -->
    <section id="profile" class="section wrap">
      <header class="shead">
        <h2 class="shead__title">A transparent, editable profile</h2>
      </header>
      <p class="lead typeset">
        The compiled profile is a plain Markdown file in your project, not inside the
        installed skill. Open it and edit any rule. The skill leaves your edits alone.
      </p>

      <figure class="filecard">
        <figcaption class="filecard__bar">
          <span class="filecard__marker" aria-hidden="true"></span>
          <span class="filecard__name">voice-profile.md</span>
          <span class="filecard__tag">example</span>
        </figcaption>
        <div class="filecard__body typeset" data-density="compact">
          <SampleProfile />
        </div>
      </figure>
    </section>

    <!-- REALTIME -->
    <section id="realtime" class="section wrap">
      <header class="shead">
        <h2 class="shead__title">A realtime voice prompt</h2>
      </header>
      <p class="lead typeset">
        Ask for the realtime prompt and the skill returns a compact, style-only module
        for a voice agent’s system prompt. It shapes delivery only, so it sits beside
        your agent’s own instructions rather than replacing them.
      </p>

      <article class="doc">
        <div class="doc__head">
          <h3 class="doc__title">Bundled default module</h3>
        </div>
        <div class="doc__body">
          <div class="typeset doc__prose">
            <RealtimePrompt />
          </div>
        </div>
      </article>
    </section>

    <!-- INSTALL -->
    <section id="install" class="section wrap">
      <header class="shead">
        <h2 class="shead__title">Install</h2>
      </header>
      <p class="lead typeset">
        Installation uses <code>npx skills</code>. The installer asks whether you want
        global or project scope. A project copy keeps its own state and never falls back
        to the global one.
      </p>

      <div class="install-card">
        <div class="install-row">
          <h3 class="install-row__name">Run</h3>
          <div class="install-row__cmd">
            <CopyCommand command={`npx skills add ${REPO}`} />
          </div>
        </div>
      </div>

      <p class="fineprint">
        It works with coding agents that read Agent Skills, including Claude Code,
        Cursor, and Codex.
      </p>

      <div class="cta">
        <a
          class="btn"
          href={`https://github.com/${REPO}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          View the repository
        </a>
        <a class="btn btn--ghost" href="#proof">Back to the examples</a>
      </div>

      <p class="body typeset">
        This skill will not help you evade AI-detection tools and makes no claim that
        its output is undetectable. Its purpose is to remove habits that make writing
        sound generic and to help you sound like yourself.
      </p>
    </section>
  </main>

  <footer class="foot-dense">
    <div class="wrap foot-dense__inner">
      <p class="foot-dense__brand">
        <span class="foot-dense__prompt" aria-hidden="true">$</span> anti-slop-slop-canon
        <span class="foot-dense__tag">— sound like yourself.</span>
      </p>
      <dl class="foot-dense__rows">
        <div class="foot-dense__row">
          <dt>repository</dt>
          <dd class="foot-dense__links">
            <a href={`https://github.com/${REPO}`} target="_blank" rel="noopener noreferrer"
              >source</a
            >
            <span aria-hidden="true">·</span>
            <a
              href={`https://github.com/${REPO}/tree/main/skills`}
              target="_blank"
              rel="noopener noreferrer">the skill</a
            >
            <span aria-hidden="true">·</span>
            <a
              href={`https://github.com/${REPO}/tree/main/docs`}
              target="_blank"
              rel="noopener noreferrer">docs</a
            >
            <span aria-hidden="true">·</span>
            <a
              href={`https://github.com/${REPO}/tree/main/evals`}
              target="_blank"
              rel="noopener noreferrer">evals</a
            >
          </dd>
        </div>
        <div class="foot-dense__row">
          <dt>on this page</dt>
          <dd class="foot-dense__links">
            <a href="#proof">default cleanup</a>
            <span aria-hidden="true">·</span>
            <a href="#states">guardrail levels</a>
            <span aria-hidden="true">·</span>
            <a href="#voice">written &amp; spoken</a>
            <span aria-hidden="true">·</span>
            <a href="#realtime">realtime prompt</a>
          </dd>
        </div>
        <div class="foot-dense__row">
          <dt>license</dt>
          <dd class="foot-dense__links">
            <span>MIT</span>
            <span aria-hidden="true">·</span>
            <a href={`https://github.com/${REPO}`} target="_blank" rel="noopener noreferrer"
              >open source</a
            >
          </dd>
        </div>
      </dl>
    </div>
  </footer>

  <script>
    const el = document.querySelector(".nav-term__star-count[data-repo]");
    if (el && el.dataset.repo) {
      fetch(`https://api.github.com/repos/${el.dataset.repo}`, {
        headers: { Accept: "application/vnd.github+json" },
      })
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const n = d && typeof d.stargazers_count === "number" ? d.stargazers_count : null;
          if (n == null) return;
          el.textContent =
            n < 1000 ? String(n) : (n / 1000).toFixed(n < 10000 ? 1 : 0).replace(/\.0$/, "") + "k";
        })
        .catch(() => {});
    }
  </script>

  <style>
    .skip {
      position: absolute;
      left: -9999px;
      top: 0;
      background: var(--color-brand);
      color: var(--color-brand-ink);
      padding: 0.6rem 1rem;
      z-index: 50;
      font-family: var(--font-code);
      font-weight: 700;
      border-radius: var(--radius-sm);
    }
    .skip:focus {
      left: 1rem;
      top: 0.75rem;
    }

    .wrap {
      width: 100%;
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 1.25rem;
    }

    /* Nav — N8 terminal command: the "links" are command flags on a CLI prompt
       line. The blinking caret signals "you'd type next" and appears only here. */
    .nav-term {
      border-bottom: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper);
    }
    .nav-term__row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem 1.5rem;
      padding-block: 0.85rem;
    }
    .nav-term__brand {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-code);
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--color-ink);
      text-decoration: none;
      white-space: nowrap;
      padding-block: 0.65rem;
      min-height: 44px;
    }
    .nav-term__prompt {
      color: var(--color-brand);
    }
    .nav-term__brand:hover {
      color: var(--color-brand);
    }
    .nav-term__flags {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.2rem 0.3rem;
    }
    .nav-term__flag {
      display: inline-flex;
      align-items: center;
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 500;
      color: var(--color-ink-2);
      text-decoration: none;
      padding: 0.65rem 0.6rem;
      min-height: 44px;
      border-radius: var(--radius-sm);
      transition:
        color 120ms var(--ease-out),
        background-color 120ms var(--ease-out);
    }
    .nav-term__flag:hover {
      color: var(--color-ink);
      background: var(--color-paper-2);
    }
    .nav-term__pill {
      border-radius: var(--radius-sm);
      padding-inline: 0.75rem;
      padding-block: 0.3rem;
      min-height: auto;
    }
    .nav-term__stars {
      border: var(--rule-thin) solid var(--color-rule);
    }
    .nav-term__star {
      color: var(--color-brand);
      margin-right: 0.4ch;
      font-size: 1.5em;
      line-height: 1;
      position: relative;
      top: -0.06em;
    }
    .nav-term__star-count {
      font-variant-numeric: tabular-nums;
    }
    .nav-term__caret {
      display: inline-block;
      width: 0.5ch;
      height: 0.9em;
      margin-left: 0.2rem;
      background: var(--color-brand);
      vertical-align: baseline;
      animation: nav-blink 1.05s steps(2) infinite;
    }
    @keyframes nav-blink {
      50% {
        opacity: 0;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .nav-term__caret {
        animation: none;
      }
    }

    /* Hero — left-biased, generous top and bottom air. The canvas is the design;
       type sits directly on the dark paper, no bloom needed for restraint. */
    .hero {
      padding-block: 3rem 4.25rem;
    }
    .hero__kicker {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.65rem;
      margin: 0 0 1.6rem;
      font-family: var(--font-code);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1;
    }
    .hero__kicker-tag {
      background: transparent;
      color: var(--color-brand);
      padding: 0.4rem 0.55rem;
      border: var(--rule-thin) solid var(--color-rule);
      border-radius: var(--radius-sm);
    }
    .hero__kicker-text {
      color: var(--color-ink-2);
    }
    .hero__title {
      margin: 0;
      font-size: clamp(2.75rem, 8vw, 5rem);
      line-height: 1.04;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .hero__lede {
      margin: 1.6rem 0 0;
      font-size: clamp(1.05rem, 1.6vw, 1.25rem);
      line-height: 1.6;
      font-weight: 400;
      max-width: 46ch;
      color: var(--color-ink-2);
    }
    .hero__sub {
      margin: 1.35rem 0 0;
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 500;
      line-height: 1.6;
      color: var(--color-ink);
      max-width: 60ch;
    }
    .hero__flow {
      margin-top: 2.75rem;
    }

    /* Sections — hairline rule between blocks, varied padding per section. */
    .section {
      padding-block: 3.75rem;
      border-top: var(--rule-thin) solid var(--color-rule);
    }
    .section--wide {
      max-width: 70rem;
    }
    .section--roomy {
      padding-block: 5.5rem;
    }

    /* Section head — single-column vertical stack, zero eyebrows. */
    .shead {
      margin: 0 0 1.35rem;
    }
    .shead__title {
      margin: 0;
      font-size: clamp(1.5rem, 3.6vw, 2.35rem);
      line-height: 1.12;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .lead {
      margin: 0 0 2rem;
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--color-ink-2);
      max-width: 60ch;
    }
    .body {
      margin-top: 1.75rem;
      color: var(--color-ink-2);
    }
    .fineprint {
      margin: 1.1rem 0 0;
      font-family: var(--font-code);
      font-size: 0.78rem;
      line-height: 1.55;
      color: var(--color-ink-2);
    }
    /* Inline code — a small elevated mono chip. */
    .fineprint code,
    .lead code,
    .body code,
    .hero__lede code {
      font-family: var(--font-code);
      font-size: 0.86em;
      background: var(--color-paper-2);
      padding: 0.08em 0.4em;
      border-radius: var(--radius-sm);
      border: var(--rule-thin) solid var(--color-rule);
      font-weight: 500;
      color: var(--color-ink);
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Card — hairline border, one lightness step above the page. No shadow. */
    .card {
      border: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-2);
      border-radius: var(--radius-md);
      overflow: clip;
    }
    .card__head {
      padding: 1.05rem 1.25rem;
      border-bottom: var(--rule-thin) solid var(--color-rule);
    }
    .card__title {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
    }
    .card__desc {
      margin: 0.35rem 0 0;
      font-family: var(--font-code);
      font-size: 0.78rem;
      color: var(--color-ink-2);
    }
    .card__body {
      padding: 1.25rem;
    }

    /* File-styled profile panel. Bleeds past the 60ch text measure on purpose —
       the one deliberate grid-break on the page. No fake window chrome: a
       labelled filename bar, one lightness step up, over real prose. */
    .filecard {
      margin: 0;
      max-width: 48rem;
      width: calc(100% + 2rem);
      margin-inline: -1rem;
      border: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-2);
      border-radius: var(--radius-lg);
      overflow: clip;
    }
    .filecard__bar {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.7rem 1.1rem;
      border-bottom: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-3);
    }
    .filecard__marker {
      width: 0.5rem;
      height: 0.5rem;
      flex: 0 0 auto;
      background: var(--color-brand);
      border-radius: 999px;
    }
    .filecard__name {
      font-family: var(--font-code);
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--color-ink);
    }
    .filecard__tag {
      margin-left: auto;
      font-family: var(--font-code);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-brand-ink);
      background: var(--color-brand);
      padding: 0.15rem 0.45rem;
      border-radius: var(--radius-sm);
    }
    .filecard__body {
      padding: 1.5rem 1.7rem 1.8rem;
    }
    .filecard__body :global(> :first-child) {
      margin-top: 0;
    }

    /* Realtime module — a labelled panel, one lightness step up. Not fake
       terminal chrome: a title row and prose beneath, nothing more. */
    .doc {
      max-width: 46rem;
      border: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-2);
      border-radius: var(--radius-md);
      overflow: clip;
    }
    .doc__head {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.35rem 1rem;
      padding: 0.9rem 1.4rem;
      border-bottom: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-3);
    }
    .doc__title {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--color-ink);
    }
    .doc__body {
      padding: 1.75rem 1.7rem 1.9rem;
    }
    .doc__prose {
      --typeset-measure: 64ch;
      --typeset-leading: 1.72;
      font-size: 1.02rem;
    }
    .doc__body :global(.doc__prose > p + p) {
      margin-top: 1.5em;
      padding-top: 1.5em;
      border-top: var(--rule-thin) solid var(--color-rule);
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 46rem) {
      .grid2 {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    /* Example text */
    .ex__caption {
      margin: 1rem 0 0.35rem;
      font-family: var(--font-code);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-ink-2);
    }
    .ex__caption:first-child {
      margin-top: 0;
    }
    /* The After label carries the accent — the same "cleaned output" signal the
       diff explorer uses for added text. */
    .ex__caption--after {
      color: var(--color-brand);
    }
    .ex__before {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink-2);
      text-decoration: line-through;
      text-decoration-thickness: 0.09em;
      text-decoration-color: var(--color-ink-2);
    }
    /* The After sits one lightness step up (elevation, not glow), so before and
       after separate physically: flat struck text vs. a raised result panel. */
    .ex__after {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      font-weight: 500;
      color: var(--color-ink);
      background: var(--color-paper-3);
      border: var(--rule-thin) solid var(--color-rule);
      border-radius: var(--radius-sm);
      padding: 0.8rem 0.95rem;
    }
    .ex__lead-line {
      margin: 0;
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink);
    }
    .ex__strucklist {
      margin: 0.4rem 0 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .ex__strucklist li {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--color-ink);
    }
    .ex__strucknum {
      font-weight: 700;
      color: var(--color-ink-2);
      text-decoration: line-through;
      text-decoration-thickness: 0.12em;
      text-decoration-color: var(--color-ink-2);
      margin-right: 0.15rem;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .ex__src {
      margin: 1.1rem 0 0;
      font-family: var(--font-code);
      font-size: 0.76rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }

    /* Onboarding choices — quiet tiles, one lightness step up. */
    .choices {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    @media (min-width: 46rem) {
      .choices {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    .choice {
      display: flex;
      gap: 0.85rem;
      padding: 1.15rem;
      border: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-2);
      border-radius: var(--radius-md);
    }
    .choice__n {
      flex: 0 0 auto;
      font-family: var(--font-code);
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1;
      color: var(--color-brand-ink);
      background: var(--color-brand);
      border-radius: var(--radius-sm);
      width: 2rem;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .choice__h {
      margin: 0 0 0.35rem;
      font-size: 1rem;
      font-weight: 700;
    }
    .choice__p {
      margin: 0;
      font-size: 0.88rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }

    .firstrun {
      margin-top: 2.5rem;
      padding-top: 2rem;
      border-top: var(--rule-thin) solid var(--color-rule);
    }
    .firstrun__h {
      margin: 0 0 1.1rem;
      font-family: var(--font-code);
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--color-ink);
    }

    /* Install — one panel holding both scopes, each a labelled row. */
    .install-card {
      border: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper-2);
      border-radius: var(--radius-md);
    }
    .install-row {
      padding: 1.4rem;
    }
    .install-row + .install-row {
      border-top: var(--rule-thin) solid var(--color-rule);
    }
    .install-row__name {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
    }
    .install-row__note {
      margin: 0.4rem 0 0;
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--color-ink-2);
    }
    .install-row__cmd {
      margin-top: 1.1rem;
    }
    .install-row__cmd :global(.cmd__code) {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      overflow-x: visible;
    }

    /* Buttons — the accent fills the primary CTA (a small, confident pill),
       never a full section. */
    .cta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
      margin-top: 2rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      min-height: 44px;
      padding: 0.8rem 1.3rem;
      font-family: var(--font-code);
      font-size: 0.85rem;
      font-weight: 700;
      white-space: nowrap;
      text-decoration: none;
      border: var(--rule-thin) solid transparent;
      border-radius: var(--radius-sm);
      background: var(--color-brand);
      color: var(--color-brand-ink);
      transition:
        background-color 120ms var(--ease-out),
        border-color 120ms var(--ease-out),
        color 120ms var(--ease-out);
    }
    .btn:hover {
      background: var(--color-brand-hover);
    }
    .btn:active {
      background: var(--color-brand);
    }
    .btn--ghost {
      background: transparent;
      border-color: var(--color-rule);
      color: var(--color-ink);
    }
    .btn--ghost:hover {
      background: var(--color-paper-2);
      border-color: var(--color-ink-2);
    }
    .btn--ghost:active {
      background: var(--color-paper-3);
    }

    /* Footer — Ft4 dense colophon: one dense monospace block, log-style rows,
       hairline rule above. Content unchanged, just denser and quieter. */
    .foot-dense {
      border-top: var(--rule-thin) solid var(--color-rule);
      background: var(--color-paper);
      padding-block: 2.5rem 3rem;
    }
    .foot-dense__brand {
      margin: 0 0 1.5rem;
      font-family: var(--font-code);
      font-size: 0.98rem;
      font-weight: 700;
      color: var(--color-ink);
    }
    .foot-dense__prompt {
      color: var(--color-brand);
    }
    .foot-dense__tag {
      font-weight: 400;
      color: var(--color-ink-2);
    }
    .foot-dense__rows {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .foot-dense__row {
      display: grid;
      grid-template-columns: 8rem 1fr;
      gap: 0.25rem 1rem;
      align-items: center;
      font-family: var(--font-code);
      font-size: 0.82rem;
    }
    @media (max-width: 34rem) {
      .foot-dense__row {
        grid-template-columns: 1fr;
        gap: 0.1rem;
      }
    }
    .foot-dense__row dt {
      color: var(--color-ink-2);
      text-transform: lowercase;
    }
    .foot-dense__row dd {
      margin: 0;
      color: var(--color-ink-2);
    }
    .foot-dense__links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.1rem 0.5rem;
    }
    .foot-dense__links a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding-inline: 0.35rem;
      color: var(--color-ink);
      text-decoration: underline;
      text-decoration-thickness: 0.08em;
      text-underline-offset: 0.15em;
      text-decoration-color: var(--color-rule);
      white-space: nowrap;
      transition: color 120ms var(--ease-out), text-decoration-color 120ms var(--ease-out);
    }
    .foot-dense__links a:hover {
      color: var(--color-brand);
      text-decoration-color: var(--color-brand);
    }
    .foot-dense__links span {
      color: var(--color-ink-2);
    }
  </style>
</Layout>
