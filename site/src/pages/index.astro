    /* Install — two labeled command blocks, one per scope. Each is a bordered
       Canon card: a serif scope name, a one-line note, and the copyable command
       seated at the foot so both commands align across the pair. */
    .installs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    @media (min-width: 46rem) {
      .installs {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
