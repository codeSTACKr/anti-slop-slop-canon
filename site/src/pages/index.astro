---
import Layout from "../layouts/Layout.astro";
import DiffExplorer from "../components/DiffExplorer.astro";
import StateExplorer from "../components/StateExplorer.astro";
import CopyCommand from "../components/CopyCommand.astro";
import TellsRemoved from "../components/TellsRemoved.astro";
import TwoModes from "../components/TwoModes.astro";
import VoiceShift from "../components/VoiceShift.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";

// Curated Markdown, compiled at build time (no client-side Markdown parser).
import { Content as SampleProfile } from "../content/voice-profile.sample.md";
import { Content as RealtimePrompt } from "../content/realtime-prompt.md";

const REPO = "codeSTACKr/anti-slop-slop-canon";

// The default-cleanup diffs use before/after pairs committed to the repository:
// the hero pair is the golden output published in repo/README.md; the punctuation
// pair is a verbatim example from skills/.../references/defaults.md § Short examples.
const heroBefore =
  "We're thrilled to announce a groundbreaking update that unlocks a seamless, robust, and transformative experience. Here's the thing: Smart Filters arrive on August 12, and early tests show a 17% drop in time spent sorting results. This isn't just an update; it's a game-changer for every workflow!";
const heroAfter =
  "Smart Filters arrive on August 12. Early tests show a 17% drop in time spent sorting results.";

const punctBefore =
  "The result is clear: keep both routes—one is faster; one is safer!";
const punctAfter = "Keep both routes. One is faster. The other is safer.";

// One release, three levels of guardrail. Every panel is OUTPUT for the same
// v2.4 facts. Panel 1 is a deliberate before: what an assistant writes with no
// help, so the AI tells belong there. Panel 2 cleans it strictly per the bundled
// rules. Panel 3 restates it in one illustrative sample voice.
const states = [
  {
    key: "none",
    tab: "No guardrails",
    caption: "What a typical assistant writes",
    body: "We're thrilled to announce that v2.4 is here, and it's a game-changer! Here's the thing—this groundbreaking release makes your whole workflow feel seamless. The CLI now has a powerful new --watch flag, cold starts are blazing fast (down from 4.2s to a mere 1.8s), and we've finally squashed that pesky Windows bug that kept dropping your environment variables. You're going to love it!",
    meta: "A realistic draft from an assistant with no help. The hype and the ornamental punctuation are exactly the habits the skill removes.",
  },
  {
    key: "default",
    tab: "With our defaults",
    caption: "Cleaned with the bundled defaults",
    body: "Version 2.4 ships Thursday. The CLI gets a --watch flag. Cold start drops from 4.2 seconds to 1.8 seconds. The Windows bug that dropped environment variables is fixed.",
    meta: "The floor everyone gets. Plain and factual, defensible line by line, with no hype and no invented claim.",
  },
  {
    key: "profile",
    tab: "With your profile",
    caption: "In a sample personal voice",
    body: "2.4 lands Thursday. The CLI finally gets a --watch flag. Cold start went from 4.2 seconds to 1.8. And that Windows bug that ate your environment variables is gone.\nShip it.",
    meta: "Illustrative of one sample profile: clipped first person, dry understatement, a fixed sign-off. It uses only the facts above. Your onboarded output would sound like you.",
  },
];

---

<Layout
  title="anti-slop-slop-canon · sound like yourself"
  description="An open-source Agent Skill that removes AI-writing habits, then learns your voice. Every example on this page is real output from the project's own rules."
>
  <a class="skip" href="#main">Skip to content</a>

  <header class="mast">
    <div class="wrap mast__inner">
      <div class="mast__brand">
        <a class="mast__word" href="#main">anti-slop-slop-canon</a>
      </div>
      <nav class="mast__nav" aria-label="Primary">
        <a class="mast__install" href="#install">Install</a>
        <a
          class="mast__star"
          href={`https://github.com/${REPO}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="mast__star-glyph"
            viewBox="0 0 24 24"
            width="14"
            height="14"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M12 2.2l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6-5.9-3.2-5.9 3.2 1.2-6.6L2.5 9.2l6.6-.9z"
            ></path>
          </svg>
          Star on GitHub
        </a>
      </nav>
    </div>
    <div class="mast__rule" role="presentation"></div>
  </header>

  <main id="main" class="wrap">
    <!-- HERO — typographic, Long Document lede -->
    <section class="hero">
      <p class="hero__kicker">
        <span class="hero__kicker-rule" aria-hidden="true"></span>
        An open-source Agent Skill
      </p>
      <h1 class="hero__title">Sound like yourself.</h1>
      <p class="hero__lede typeset">
        <code>anti-slop-slop-canon</code> removes the habits that make writing sound
        machine-made, then learns a transparent, editable profile of your voice. One
        profile for what you write and what you say aloud.
      </p>
      <p class="hero__sub">
        Every example below is <mark class="mark">real output</mark> from the project's
        own rules.
      </p>

      <div class="hero__flow">
        <TellsRemoved />
      </div>
    </section>

    <Separator />

    <!-- PROOF — default cleanup, interactive diff -->
    <section id="proof" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">01</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">The floor</span>
      </p>
      <h2 class="h2">Default cleanup, before you do anything</h2>
      <p class="lead typeset">
        Out of the box it strips hype, canned framing, and ornamental punctuation
        without inventing a claim the source never made.
      </p>

      <div class="stack">
        <DiffExplorer
          id="hero"
          label="Product update · rewrite"
          before={heroBefore}
          after={heroAfter}
          note="Same facts. Removed the hype, a manufactured contrast, and an exclamation point."
        />
        <DiffExplorer
          id="punct"
          label="Punctuation · rewrite"
          before={punctBefore}
          after={punctAfter}
          note="No em dash, no semicolon, no exclamation point, no mid-sentence colon. Verbatim example from the bundled defaults."
        />
      </div>
    </section>

    <Separator />

    <!-- THREE STATES -->
    <section id="states" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">02</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">Three levels of guardrail</span>
      </p>
      <h2 class="h2">The same release, three levels of guardrail</h2>
      <p class="lead typeset">
        Every panel is output for the same v2.4 release. What changes is how much
        guidance the agent had.
      </p>
      <StateExplorer id="release" states={states} />
      <p class="fineprint">
        The last panel illustrates one sample profile, not any real person's output.
      </p>
    </section>

    <Separator />

    <!-- WRITTEN & SPOKEN -->
    <section id="voice" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">03</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">One profile, two modes</span>
      </p>
      <h2 class="h2">Written and spoken</h2>
      <p class="lead typeset">
        The same profile covers what people read and what they hear.
      </p>

      <TwoModes />

      <div class="grid2">
        <Card className="ex">
          <CardHeader>
            <CardTitle>Written</CardTitle>
            <CardDescription>Blog posts, docs, and social posts</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="ex__caption">Before</p>
            <p class="ex__before">This isn't a redesign. It's a reset.</p>
            <p class="ex__caption">After</p>
            <p class="ex__after">
              This redesign changes the navigation and search model.
            </p>
            <p class="ex__src">
              A blog opener with the contrast framing removed, from the bundled defaults.
            </p>
          </CardContent>
        </Card>

        <Card className="ex">
          <CardHeader>
            <CardTitle>Spoken</CardTitle>
            <CardDescription>Video scripts, narration, voice-agent replies</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="ex__caption">Written</p>
            <p class="ex__lead-line">Deploying takes three steps:</p>
            <ol class="ex__list">
              <li>Pull the latest main.</li>
              <li>Run the database migration.</li>
              <li>Restart the workers.</li>
            </ol>
            <p class="ex__caption">Read aloud</p>
            <p class="ex__after">
              Deploying takes three steps. First, pull the latest main. Then run the
              database migration. Last, restart the workers.
            </p>
            <p class="ex__src">
              The list numbers drop out, so they are never read aloud. The order stays
              the same.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <Separator />

    <!-- ONBOARDING -->
    <section id="onboarding" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">04</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">How it learns your voice</span>
      </p>
      <h2 class="h2">It builds a profile from your own writing</h2>
      <p class="lead typeset">
        You give it a few samples. It finds the traits that are your voice, compiles a
        profile you approve, and writes in your voice from then on.
      </p>

      <VoiceShift />

      <div class="firstrun">
        <h3 class="firstrun__h">The first time, it offers three ways to start</h3>
        <div class="choices choices--compact">
          <div class="choice">
            <span class="choice__n">1</span>
            <div>
              <h4 class="choice__h">Personalize now</h4>
              <p class="choice__p">
                A short, adaptive interview. One question at a time.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">2</span>
            <div>
              <h4 class="choice__h">Use the defaults</h4>
              <p class="choice__p">
                Skip setup and use the bundled defaults right away.
              </p>
            </div>
          </div>
          <div class="choice">
            <span class="choice__n">3</span>
            <div>
              <h4 class="choice__h">Defer</h4>
              <p class="choice__p">
                Not now. Use the defaults and ask again later.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Separator />

    <!-- PROFILE -->
    <section id="profile" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">05</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">Nothing hidden</span>
      </p>
      <h2 class="h2">A transparent, editable profile</h2>
      <p class="lead typeset">
        The compiled profile is a plain Markdown file in your project, not inside the
        installed skill. Open it and edit any rule. The skill leaves your edits alone.
      </p>

      <figure class="filecard">
        <figcaption class="filecard__bar">
          <span class="filecard__dot" aria-hidden="true"></span>
          <span class="filecard__name">voice-profile.md</span>
          <span class="filecard__tag">example</span>
        </figcaption>
        <div class="filecard__body typeset" data-density="compact">
          <SampleProfile />
        </div>
      </figure>
    </section>

    <Separator />

    <!-- REALTIME -->
    <section id="realtime" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">06</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">For voice agents</span>
      </p>
      <h2 class="h2">A realtime voice prompt</h2>
      <p class="lead typeset">
        Ask for the realtime prompt and the skill returns a compact, style-only module
        for a voice agent's system prompt. It shapes delivery only, so it sits beside
        your agent's own instructions rather than replacing them.
      </p>

      <Card className="doc">
        <CardHeader>
          <CardTitle>Bundled default module</CardTitle>
          <CardDescription>
            Verbatim from <code>assets/realtime-voice-prompt.md</code>
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="typeset" data-density="compact">
            <RealtimePrompt />
          </div>
        </CardContent>
      </Card>
    </section>

    <Separator />

    <!-- INSTALL -->
    <section id="install" class="section">
      <p class="eyebrow">
        <span class="eyebrow__num">07</span>
        <span class="eyebrow__rule" aria-hidden="true"></span>
        <span class="eyebrow__text">Getting started</span>
      </p>
      <h2 class="h2">Install</h2>
      <p class="lead typeset">
        Installation uses <code>npx skills</code>. A project copy keeps its own state
        and never falls back to the global one.
      </p>

      <div class="installs">
        <div class="install-block">
          <h3 class="install-block__name">Global</h3>
          <p class="install-block__note">
            Activates the skill in every project on the machine.
          </p>
          <div class="install-block__cmd">
            <CopyCommand command={`npx skills add ${REPO} -g`} />
          </div>
        </div>
        <div class="install-block">
          <h3 class="install-block__name">Project</h3>
          <p class="install-block__note">
            Scoped to one repository, with its own isolated state.
          </p>
          <div class="install-block__cmd">
            <CopyCommand command={`npx skills add ${REPO}`} />
          </div>
        </div>
      </div>

      <p class="fineprint">
        It works with coding agents that read Agent Skills, including Claude Code,
        Cursor, and Codex.
      </p>

      <div class="cta">
        <a
          class={cn(buttonVariants({ variant: "default" }), "h-11 px-5 text-[0.95rem]")}
          href={`https://github.com/${REPO}`}>View the repository</a
        >
        <a
          class={cn(buttonVariants({ variant: "outline" }), "h-11 px-5 text-[0.95rem]")}
          href="#proof">Back to the examples</a
        >
      </div>

      <p class="body typeset">
        This skill will not help you evade AI-detection tools and makes no claim that
        its output is undetectable. Its purpose is to remove habits that make writing
        sound generic and to help you sound like yourself.
      </p>
    </section>
  </main>

  <footer class="colophon">
    <div class="wrap colophon__inner">
      <div class="colophon__brand">
        <span class="colophon__word">anti-slop-slop-canon</span>
        <span class="colophon__tag">Sound like yourself.</span>
      </div>
      <div class="colophon__cols">
        <div>
          <h2 class="colophon__h">Repository</h2>
          <ul>
            <li><a href={`https://github.com/${REPO}`}>Source</a></li>
            <li>
              <a href={`https://github.com/${REPO}/tree/main/skills`}>The skill</a>
            </li>
            <li><a href={`https://github.com/${REPO}/tree/main/docs`}>Docs</a></li>
            <li><a href={`https://github.com/${REPO}/tree/main/evals`}>Evals</a></li>
          </ul>
        </div>
        <div>
          <h2 class="colophon__h">On this page</h2>
          <ul>
            <li><a href="#proof">Default cleanup</a></li>
            <li><a href="#states">Guardrail levels</a></li>
            <li><a href="#voice">Written &amp; spoken</a></li>
            <li><a href="#realtime">Realtime prompt</a></li>
          </ul>
        </div>
        <div>
          <h2 class="colophon__h">License</h2>
          <ul>
            <li>MIT licensed</li>
            <li><a href={`https://github.com/${REPO}`}>Open source</a></li>
          </ul>
        </div>
      </div>
    </div>
  </footer>

  <style>
    .skip {
      position: absolute;
      left: -9999px;
      top: 0;
      background: var(--color-foreground);
      color: var(--color-background);
      padding: 0.6rem 1rem;
      z-index: 50;
      border-radius: 0 0 var(--radius-md) 0;
    }
    .skip:focus {
      left: 0;
    }

    .wrap {
      width: 100%;
      max-width: 60rem;
      margin-inline: auto;
      padding-inline: 1.25rem;
    }

    /* Masthead */
    .mast {
      padding-top: 1.4rem;
    }
    .mast__inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem 1.5rem;
      padding-bottom: 1rem;
    }
    .mast__brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .mast__word {
      font-family: var(--font-code);
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--color-foreground);
      text-decoration: none;
    }
    /* Star-on-GitHub pill — a plain call to action, no count and no fetch.
       The star glyph carries the signature amber; text keeps full ink contrast. */
    .mast__star {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.28rem 0.7rem;
      border: 1px solid var(--color-rule);
      border-radius: 999px;
      background: var(--color-card);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 600;
      line-height: 1;
      color: var(--color-foreground);
      text-decoration: none;
      white-space: nowrap;
      transition:
        background-color 150ms var(--ease-out),
        border-color 150ms var(--ease-out);
    }
    .mast__star:hover {
      background: var(--color-secondary);
      border-color: var(--color-input);
    }
    .mast__star-glyph {
      flex: 0 0 auto;
      color: var(--color-highlight-strong);
    }
    .mast__nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem 1rem;
    }
    .mast__nav a {
      font-family: var(--font-ui);
      font-size: 0.86rem;
      color: var(--color-muted-foreground);
      text-decoration: none;
      white-space: nowrap;
    }
    .mast__nav a:hover {
      color: var(--color-foreground);
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }
    .mast__rule {
      height: 0;
      border-top: 2px solid var(--color-foreground);
      border-bottom: 1px solid var(--color-foreground);
      padding-bottom: 3px;
    }

    /* Hero */
    .hero {
      padding-block: 4.5rem 3.5rem;
    }
    .hero__kicker {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin: 0 0 1.4rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
    .hero__kicker-rule {
      display: block;
      width: 2rem;
      height: 2px;
      flex: 0 0 auto;
      background: var(--color-primary);
    }
    .hero__title {
      margin: 0;
      font-size: clamp(3rem, 9.5vw, 6rem);
      line-height: 0.98;
      font-weight: 600;
      letter-spacing: -0.028em;
    }
    .hero__lede {
      margin: 1.75rem 0 0;
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      line-height: 1.55;
      max-width: 40ch;
    }
    .hero__sub {
      margin: 1.35rem 0 0;
      font-family: var(--font-ui);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-muted-foreground);
      max-width: 60ch;
    }
    .hero__flow {
      margin-top: 3.25rem;
    }

    /* Sections */
    .section {
      padding-block: 5.25rem;
    }

    /* Numbered spec-sheet eyebrow — number (mono, accent) · short rule · label. */
    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin: 0 0 1rem;
    }
    .eyebrow__num {
      font-family: var(--font-code);
      font-size: 0.92rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--color-primary);
      font-variant-numeric: tabular-nums;
    }
    .eyebrow__rule {
      display: block;
      width: 1.75rem;
      height: 1px;
      flex: 0 0 auto;
      background: var(--color-primary);
      opacity: 0.55;
    }
    .eyebrow__text {
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--color-muted-foreground);
    }
    .h2 {
      margin: 0;
      font-size: clamp(1.9rem, 5vw, 3rem);
      line-height: 1.06;
      font-weight: 600;
      letter-spacing: -0.02em;
    }
    .lead {
      margin: 1.1rem 0 2.25rem;
      font-size: 1.12rem;
    }
    .body {
      margin-top: 1.75rem;
    }
    .fineprint {
      margin: 1rem 0 0;
      font-family: var(--font-ui);
      font-size: 0.82rem;
      line-height: 1.55;
      color: var(--color-muted-foreground);
    }
    .fineprint code,
    .lead code,
    .body code,
    .hero__lede code {
      font-family: var(--font-code);
      font-size: 0.86em;
      background: var(--color-muted);
      padding: 0.08em 0.32em;
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* File-styled profile panel */
    .filecard {
      margin: 0;
      max-width: 44rem;
      border: 1px solid var(--color-rule);
      border-radius: var(--radius-lg);
      background: var(--color-card);
      overflow: hidden;
    }
    .filecard__bar {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.7rem 1.1rem;
      border-bottom: 1px solid var(--color-rule);
      background: var(--color-secondary);
    }
    .filecard__dot {
      width: 0.6rem;
      height: 0.6rem;
      flex: 0 0 auto;
      border-radius: 50%;
      border: 1.5px solid var(--color-primary);
    }
    .filecard__name {
      font-family: var(--font-code);
      font-size: 0.86rem;
      font-weight: 600;
      color: var(--color-foreground);
    }
    .filecard__tag {
      margin-left: auto;
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--color-muted-foreground);
    }
    .filecard__body {
      padding: 1.4rem 1.7rem 1.7rem;
    }
    .filecard__body :global(> :first-child) {
      margin-top: 0;
    }
    .filecard__note {
      max-width: 44rem;
      margin-inline: 0;
      text-align: left;
    }

    /* Realtime prompt card (§06). A comfortable reading measure for the prose,
       left-aligned to the content column like the profile panel. Not shrink-to-fit,
       not full-width. */
    :global(.doc) {
      max-width: 44rem;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 46rem) {
      .grid2 {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    /* Example cards */
    .ex__caption {
      margin: 0.9rem 0 0.3rem;
      font-family: var(--font-ui);
      font-size: 0.74rem;
      font-weight: 600;
      letter-spacing: 0.05em;
